# Normalize text files in repository using LF
* text=auto eol=lf

# Salesforce metadata/code
*.cls text eol=lf
*.trigger text eol=lf
*.xml text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.page text eol=lf
*.component text eol=lf
*.design text eol=lf
*.app text eol=lf
*.cmp text eol=lf
*.auradoc text eol=lf
*.svg text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
