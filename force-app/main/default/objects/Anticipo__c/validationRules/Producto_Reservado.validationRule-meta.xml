<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Producto_Reservado</fullName>
    <active>true</active>
    <errorConditionFormula>ISNEW() &amp;&amp;
NOT(ISNULL(Producto__c)) &amp;&amp;
