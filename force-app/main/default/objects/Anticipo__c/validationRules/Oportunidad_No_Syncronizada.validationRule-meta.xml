<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Oportunidad_No_Syncronizada</fullName>
    <active>true</active>
    <errorConditionFormula>ISNEW() &amp;&amp;
 (
					ISNULL(Oportunidad__r.Synced_Quote__c)
	)</errorConditionFormula>
    <errorDisplayField>Oportunidad__c</errorDisplayField>
    <errorMessage>La oportunidad requiere tener un presupuesto principal syncronizado.</errorMessage>
</ValidationRule>
