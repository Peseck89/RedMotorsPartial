<aura:component
  implements="force:hasRecordId,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes"
  access="global" controller="CommunityCalendarController">
  <aura:attribute name="navigateToComponent2" type="Aura.Component[]" />
  <html>
    <head>
      <meta charset="utf-8" />
      <meta name="viewport"
        content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
      <title> Walking Mini </title>
      <meta name="description" content="" />
    </head>
    <body class="THIS">
      <div class="container">
        <section class="info-header">
          <h1>Bienvenid@</h1>
          <h2>¿List@ para descubrir tu próximo vehículo?</h2>
          <h3>¡Comencemos!</h3>
        </section>
        <section class="main-section">
          <div class="m-s-left">
            <lightning:button label="Iniciar" onclick="{!c.navigateToComponent2}" />
          </div>
          <div>
            <img src="{!$Resource.MiniHomeCar}" class="car-image" />
          </div>
        </section>
      </div>
    </body>
  </html>
</aura:component>