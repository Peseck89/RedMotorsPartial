<aura:component implements="flexipage:availableForRecordHome,lightning:availableForFlowActions,force:hasSObjectName,force:lightningQuickAction,lightning:actionOverride,force:appHostable,flexipage:availableForAllPageTypes,force:hasRecordId,lightning:isUrlAddressable"  access="global" controller="cT_getEventsCalendar">
    <aura:handler name="init" value="{!this}" action="{!c.init}"/>
    <aura:attribute name="userId" type="Id" />
    <aura:attribute name="events" type="Event[]" />
    <aura:attribute name="modelosVehiculos" type="User[]" />
    <aura:attribute name="selectedValue" type="String" />
    <aura:attribute name="selectedDate" type="Date" />
    <aura:attribute name="selectedValueAsesor" type="String" />
    <aura:attribute name="actions" type="Object[]"/>

    <lightning:card variant="Narrow" >
    
       
        
        <article class="slds-card">
            <div class="slds-card__header slds-grid">
                <header class="slds-media slds-media_center slds-has-flexi-truncate">
                <div class="slds-media__figure">
                    <span class="slds-icon_container slds-icon-standard-contact" title="Reservar:">
                        <lightning:icon iconName="standard:capacity_plan" alternative-text="Reservar:"></lightning:icon>
                        <span class="slds-assistive-text">Reservar: </span>
                    </span>
                </div>
                <div class="slds-media__body">
                    <h2 class="slds-card__header-title">
                        <a href="#" class="slds-card__header-link slds-truncate" title="Reservar:">
                            <span>Revisar eventos de asesor:</span>
                        </a>
                    </h2>
                </div>
            </header>
            </div>
            <div class="slds-card__body slds-grid">
                <div class="slds-form__row">
                    <div class="slds-form__item" role="listitem">
                        <div class="slds-form-element slds-form-element_horizontal ">  
                            <lightning:select name="selectVehicle" label="Asesor: " required="true" value="{! v.selectedValue}"  messageWhenValueMissing="Se necesita escoger un Asesor.">
                                <option value="">--Asesor--</option>
                                <aura:iteration items="{! v.modelosVehiculos}" var="modelo">
                                    <option value="{! modelo.Id}" text="{! modelo.Name}" selected="{! modelo.selected}"/>
                                </aura:iteration>
                            </lightning:select>
                        </div>
                        
                    </div>

                    <div class="slds-form__item" role="listitem">
                        <div class="slds-form-element slds-form-element_horizontal ">  
                                
                            <lightning:input type="date" required="true" name="input1" value = "{! v.selectedDate}" label="Fecha" />
                        </div>
                    </div>

                    <div class="slds-form__item" role="listitem">
                        <div class="slds-form-element slds-form-element_horizontal ">  
                                
                            <lightning:button variant="brand" label="Buscar" title="Brand action" onclick="{! c.doSomething }" />
                        </div>
                        <div class="slds-form-element slds-form-element_horizontal ">  
                                
                            <lightning:button variant="destructive" label="Limpiar" title="Destructive action" onclick="{! c.clean }"/>

                            
                        </div>
                    </div>

                </div>        
            </div>
 
            <div class="table-responsive text-nowrap" style="margin: 25px;">
                <table id="table" class="slds-table slds-table_bordered slds-table_edit slds-table_fixed-layout slds-table_resizable-cols" role="grid" style="">
                <thead>
                    <tr class="text-nowrap">
                        <th style="text-align: left;">Fecha y Hora Inicio</th>
                        <th style="text-align: left;">Fecha y Hora Fin</th>
                        <th style="text-align: left;">Asesor</th>

                    </tr>
                </thead>
                <tbody id="dataRows">

                </tbody>
                </table>
            </div>
                                
            <footer class="slds-card__footer">

            </footer>
        </article>       
    </lightning:card>
    
</aura:component>