<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,lightning:actionOverride,lightning:isUrlAddressable,force:lightningQuickAction"  access="global" >
    <aura:attribute name="recordId" type="String"/>
    <!--<aura:handler name="init" value="{!this}" action="{!c.init}"/>-->
    <aura:html tag="style">
        .slds-modal__container{ 
            height : auto; width: 80%; max-width: 70vh; 
          } 
          .modal-body{ 
            height : 60vh !important; 
            max-height: 85vh !important; 
          } 
    </aura:html>      
  
	
    <c:selectTipoDeCargo recId="{!v.recordId}"/>

</aura:component>