<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,lightning:actionOverride" access="global" controller="ButtonNewCaseController">
    
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="isAsesor" type="Boolean" default="false" />
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <aura:if isTrue="{!v.isAsesor}">
        <div class="slds-form__item" role="listitem">
            <div class="slds-form-element slds-form-element_horizontal ">  
                <span>No se puede generar casos manualmente </span>
            </div>
        </div>
        <aura:set attribute="else">
            <lightning:button label="New Record" onclick="{!c.handleNewRecord}"/>
        </aura:set>
    </aura:if>
    
</aura:component>