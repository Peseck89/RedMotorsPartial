<aura:component implements="flexipage:availableForAllPageTypes,force:hasRecordId,lightning:actionOverride,lightning:isUrlAddressable,force:lightningQuickActionWithoutHeader"  access="global" controller="ReservaOportunidadController" >
    
    <aura:attribute name="currentOpp" type="Opportunity" />
    <aura:attribute name="holder" type="Product2" />
    <aura:attribute name="routeInput" type="Map" />
    <aura:attribute name="selectedValue" type="String" />
    <aura:attribute name="modelosVehiculos" type="Product2[]" />
    
    <aura:attribute name="fPage1" type="Boolean" default="true" />
    <aura:attribute name="fPage2" type="Boolean" default="false" />
    <aura:attribute name="fPage3" type="Boolean" default="false" />
    <aura:attribute name="Anticipo" type="Boolean" default="false" />
    <aura:attribute name="isLoading" type="Boolean" default="false" />
    
    
    <aura:handler name="init" action="{!c.doInit}" value="{!this}"/>
    
    <lightning:card variant="Narrow">
        <div class="slds-card__header slds-grid">
            <header class="slds-media slds-media_center slds-has-flexi-truncate">
                <div class="slds-media__figure">
                    <span class="slds-icon_container slds-icon-standard-contact" title="Reservar:">
                        <lightning:icon iconName="standard:products" alternative-text="Reservar:"></lightning:icon>
                        <span class="slds-assistive-text">Reservar: </span>
                    </span>
                </div>
                <div class="slds-media__body">
                    <h2 class="slds-card__header-title">
                        <a href="#" class="slds-card__header-link slds-truncate" title="Reservar:">
                            <span>Reservar:</span>
                        </a>
                    </h2>
                </div>
            </header>
        </div>

        <aura:if isTrue="{! v.isLoading }">
            <div class="slds-align_absolute-center" style="height: 5rem;">
                <lightning:spinner alternativeText="Loading" size="large" />
            </div>
        </aura:if>

        <aura:renderIf isTrue="{! v.fPage1}">
            <div class="slds-form__row">
                <div class="slds-form__item" role="listitem">
                    <div class="slds-form-element slds-form-element_horizontal ">  
                        <lightning:select name="selectVehicle" label="Vehiculo: " required="true" value="{! v.selectedValue}" messageWhenValueMissing="Se necesita escoger un Vehiculo.">
                            <option value="">--Vehiculo--</option>
                            <aura:iteration items="{! v.modelosVehiculos}" var="modelo">
                                <option value="{! modelo.Id}" text="{! modelo.Name}" selected="{! modelo.selected}"/>
                            </aura:iteration>
                        </lightning:select>
                    </div>
                </div>
            </div>
            
            
            
            <footer class="slds-card__footer" style="display: flex;justify-content: space-between;">
                <div></div> 
                <div>                
                    <lightning:button variant="brand-outline" label="Cancelar" title="Cancelar" onclick="{! c.onCancel}" class="slds-var-m-left_small" />
                    <lightning:button variant="brand" label="Continuar" title="Continuar" onclick="{! c.continueReserva}" class="slds-var-m-left_x-small" />                                                   
                </div>               
            </footer>  
            
            
        </aura:renderIf>
        
        <aura:renderIf isTrue="{! v.fPage2}">
            
            <aura:renderIf isTrue="{! v.Anticipo}">
                <div class="slds-form__item" role="listitem">
                    <div class="slds-form-element slds-form-element_horizontal ">  
                        <span>¿Desea reservar el vehículo {! v.holder.Name}?</span>
                    </div>
                </div>
                <footer class="slds-card__footer" style="display: flex;justify-content: space-between;">
                    <div></div> 
                    <div>                
                        <lightning:button variant="brand-outline" label="Cancelar" title="Cancelar" onclick="{! c.onCancel}" class="slds-var-m-left_small" />
                        <lightning:button variant="brand" label="Reservar" title="Reservar" onclick="{! c.handleReserva}" class="slds-var-m-left_x-small" disabled="{! v.isLoading }"/>                                                   
                    </div>               
                </footer> 
            </aura:renderIf>
            
            <aura:renderIf isTrue="{! !v.Anticipo}">
                
                <div class="slds-form__item" role="listitem">
                    <div class="slds-form-element slds-form-element_horizontal ">  
                        <span>El vehículo {! v.holder.Name} no tiene anticipo, ¿Desea reservarlo? </span>
                    </div>
                </div>
                
                <footer class="slds-card__footer" style="display: flex;justify-content: space-between;">
                    <div></div> 
                    <div>                
                        <lightning:button variant="brand-outline" label="Cancelar" title="Cancelar" onclick="{! c.onCancel}" class="slds-var-m-left_small" />
                        <lightning:button variant="brand" label="Reservar" title="Reservar" onclick="{! c.handleReserva}" class="slds-var-m-left_x-small" disabled="{! v.isLoading }" />                                                   
                    </div>               
                </footer>
            </aura:renderIf>
        </aura:renderIf>
        
        <aura:renderIf isTrue="{! v.fPage3}">
            <aura:if isTrue="{! v.holder == null}" >
                <div class="slds-form__item" role="listitem">
                    <div class="slds-form-element slds-form-element_horizontal ">  
                        <span>Error 01: "EL ARTICULO INDICADO ES INVALIDO."</span>
                    </div>
                </div>
            </aura:if>
            <aura:if isTrue="{! v.holder != null}">
                <div class="slds-form__item" role="listitem">
                    <div class="slds-form-element slds-form-element_horizontal ">  
                        <span>El vehículo {! v.holder.Name} con Vin: {! v.holder.vin__c} ha sido reservado.</span>
                    </div>
                </div>
            </aura:if>
            <footer class="slds-card__footer" style="display: flex;justify-content: space-between;">
                <div></div> 
                <div>                
                    <lightning:button variant="brand" label="Aceptar" title="Aceptar" onclick="{! c.onCancel}" class="slds-var-m-left_x-small" />                                                   
                </div>               
            </footer>
            
        </aura:renderIf>
        
    </lightning:card>
</aura:component>