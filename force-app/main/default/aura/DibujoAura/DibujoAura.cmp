<aura:component implements="flexipage:availableForRecordHome,force:hasRecordId" access="global" controller="DibujoController">
    <aura:attribute name="recordId" type="Id"/>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <c:anomaliaViewer recId="{!v.recordId}" />
</aura:component>