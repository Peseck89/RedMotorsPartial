<aura:component  controller="BMW_presupuestoVencido" implements="force:lightningQuickAction,force:hasRecordId">
    <aura:html tag="style">
        .slds-modal__container {
             width : 80% !important;
             max-width : 80% !important;
         }
    </aura:html>
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"/>
    <aura:attribute name="recordId" type="String" />
        <aura:attribute name="FechaVigente" type="String" />
    <aura:if isTrue="{!v.FechaVigente == 'VENCIDO'}">  
           "Este presupuesto ya expiró, por favor realizar un presupuesto nuevo"   
        <aura:set attribute="else"> 
            <c:cT_cloneQuote recordId="{!v.recordId}"></c:cT_cloneQuote>  
      </aura:set>     
   </aura:if>   
</aura:component>