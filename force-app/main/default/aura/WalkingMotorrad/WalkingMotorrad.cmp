<aura:component
  implements="force:hasRecordId,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes,force:appHostable"
  access="global" controller="CommunityCalendarController">
  
  <aura:handler name="init" value="{!this}" action="{!c.doInit}"/> <!-- Nuevo handler -->
  <aura:attribute name="marca" type="String" default="motorrad"/> <!-- Atributo para almacenar la marca -->
  <html>
    <head>
      <meta charset="utf-8" />
      <meta name="viewport"
        content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
      <title> Walking Motorrad </title>
      <meta name="description" content="" />
    </head>
    <body class="THIS">
      <div class="container">
        <section class="info-header">
          <h1>Bienvenid@</h1>
          <h2>¿List@ para descubrir tu próximo vehículo?</h2>
          <h3>¡Comencemos!</h3>
        </section>
        <section class="main-section">
          <div class="m-s-left">
            <lightning:button label="Iniciar" onclick="{!c.navigateToComponent2}" />
          </div>
          <div>
            <aura:if isTrue="{!v.marca == 'motorrad'}">
              <img src="{!$Resource.MotorradHome}" class="car-image"/>
            </aura:if>
            <aura:if isTrue="{!v.marca == 'kawasaki'}">
              <img src="{!$Resource.KawasakiHome}" class="car-image"/> 
            </aura:if>
            <aura:if isTrue="{!v.marca == 'indian'}">
              <img src="{!$Resource.IndianHome}" class="car-image"/>
            </aura:if>
            <aura:if isTrue="{!v.marca == 'polaris'}">
              <img src="{!$Resource.PolarisHome}" class="car-image"/>
            </aura:if>
          </div>
        </section>
      </div>
    </body>
  </html>
</aura:component>