<aura:component
    implements="flexipage:availableForAllPageTypes,force:hasRecordId,lightning:actionOverride,lightning:isUrlAddressable,force:lightningQuickActionWithoutHeader"
    access="global"
    >
    <aura:attribute name="recordId" type="String" />
    <aura:handler name="init" value="{!this}" action="{!c.init}"/>
    <aura:html tag="style">
        .slds-modal__container {
        min-width: 90vw;
        }
    </aura:html>
    <p>{!recordId}</p>
        <c:cT_searchProductos recId="{!v.recordId}"  />

</aura:component>