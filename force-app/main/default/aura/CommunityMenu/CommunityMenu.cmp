                                                                <div class="slds-modal__container">
                                                                    <!-- Modal/Popup Box Header Starts here-->
                                                                    <header class="slds-modal__header">

                                                                        <div id="creandocita1_ popup1_">
                                                                            <button
                                                                                style="top:0 !important;width:17px !important;right:1px !important;border: none !important;border-radius: 50%; "
                                                                                class="slds-button slds-button_icon slds-modal__close mybuttonx"
                                                                                title="Close" onclick="{!c.reload}">
                                                                                X
                                                                            </button>
                                                                            <ui:message class="citation-message-Confirm"
