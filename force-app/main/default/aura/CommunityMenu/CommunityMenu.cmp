                                                    <!-- Modals -->

                                                    <div class="container">
                                                        <div class="row row-header-custom" id="verificarSection">

                                                            <div class="row">
                                                                <div class="col-md-12">
                                                                    <lightning:combobox class="start-select"
                                                                        label="Seleccione el servicio: "
                                                                        aura:id="options" name="options"
                                                                        placeholder="{!v.Servicio}"
                                                                        options="{! v.optionsService }"
                                                                        onchange="{!c.handleOnChangeSelectedService}"
                                                                        value="{!v.selectedValue}">

                                                                    </lightning:combobox>

                                                                </div>
                                                            </div>
                                                            <!-- <div class="row"> -->
                                                            <!--<aura:if isTrue="{!v.serviceSelected == 'Mecánica Rápida'}">-->
                                                            <div class="additionalServices" id="additionalServices"
                                                                style="display:none">
                                                                <div class="sidebar-events" id="additionalTableService"
                                                                    style="padding: 0px 0px 0px 0px;">
                                                                </div>
                                                                <!-- <ui:inputText class="paddingText"  label="Desea reportar un fallo" value="{!v.additionalComments}" updateOn="change" change="{!c.onChangeComment}" /> -->
                                                                <div class="row additionalServices"
                                                                    id="seleccionVehiculo">
                                                                    <div class="col-md-12" style="margin:0;">
                                                                        <lightning:combobox class="form-control"
                                                                            name="ownVehicule"
                                                                            label="Desea reportar un fallo: "
                                                                            placeholder="Desea reportar un fallo"
                                                                            options="{!v.optionsErrors}"
                                                                            id="userOptions"
                                                                            onchange="{!c.onChangeComment}" />
                                                                    </div>
                                                                </div>

                                                            </div>
                                                            <!--</aura:if>-->
                                                            <div class="errorMessage" id="errorMessage"
                                                                style="display:none;">
                                                                <div
                                                                    style="background-color: #f8d7da;color: #721c24;font-size: 20px;border-color: #f5c6cb;border-radius: 4px; padding: 20px; border: 1px solid transparent;">
                                                                    Para continuar, debes de seleccionar al menos un
                                                                    servicio o agregar un comentario.</div>

                                                                <!-- </div> -->
                                                                <br />

                                                            </div>
                                                            <div class="col-md-6" id="vehicleSelection"
                                                                style="display:none">
                                                                <!-- <lightning:combobox class="form-control" name="vehicle" label="Seleccione el tipo de vehículo: " placeholder="Tipo Vehículo" options="{!v.optionsVehicule}" onchange="{! c.handleOnChangeVehiculeSelection }" /> -->
                                                            </div>
                                                            <div class="row additionalServices" id="seleccionVehiculo">

                                                                <div class="col-md-12" id="ownVehicule"
                                                                    style="display:none;margin:0;">
                                                                    <aura:if isTrue="{!v.hasNoAssets}">
                                                                        <ui:message title="Error." severity="Error"
                                                                            closable="false">No tienes vehículo asociado
                                                                            en esta marca, click <a
                                                                                onclick="{! c.mostrarCambiarMarca }">aquí</a>
                                                                            para cambiar de marca.</ui:message>
                                                                        <aura:set attribute="else">
                                                                            <aura:if
                                                                                isTrue="{!v.vehicleSelected=='Vehículo Propio'}">
                                                                                <lightning:combobox class="form-control"
                                                                                    name="ownVehicule"
                                                                                    label="Seleccione vehículo: "
                                                                                    placeholder="*En caso que su vehículo no esta asignado a su perfil por favor diríjase a Asistencia en línea"
                                                                                    options="{!v.userAssets}"
                                                                                    id="userAssets"
                                                                                    onchange="{!c.handleOnOwnChange}"
                                                                                    onclick="{!c.handleKMVisivility}" />
                                                                            </aura:if>
                                                                        </aura:set>
                                                                    </aura:if>
                                                                </div>


                                                                <div class="col-md-6" id="vehiculeId"
                                                                    style="display:none; margin:0;">
                                                                    <lightning:input
                                                                        class="form-control-custom form-control"
                                                                        label="Ingrese la placa del vehículo "
                                                                        value="{!v.vehicleId}" placeholder="Placa"
                                                                        onchange="{! c.handleOnChangeVehiculeId }" />
                                                                </div>
                                                            </div>

                                                            <div class="contenedorTablaFea"
                                                                style="margin-bottom: 20px;">
                                                                <div id="vehicleInfo"
                                                                    class="row additionalServices tablaInteriorInfo"
                                                                    style="display:none;margin-left: 12px;width: 94%;margin-bottom:20px !important;">
                                                                    <p class="textoInformacion"
                                                                        style="font-size: 1.6rem">Información de su
                                                                        vehículo:</p>
                                                                    <br />
                                                                    <table id="vehicleInfoTable"
                                                                        class="textoInformacion" style="font-size:18px">
                                                                        <thead>
                                                                            <tr>
                                                                                <th style="width: 20%;">Marca</th>
                                                                                <th style="width: 20%;">Modelo</th>
                                                                                <th style="width: 20%;">Año</th>
                                                                                <th style="width: 20%;">Color</th>
                                                                                <th style="width: 20%;">Placa</th>
                                                                            </tr>
                                                                        </thead>
                                                                        <tbody>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                            <div id="errorExistingCitation" style="display:none">
                                                                <div
                                                                    style="background-color: #f8d7da;color: #721c24;font-size: 20px;border-color: #f5c6cb;border-radius: 4px; padding: 15px; border: 1px solid transparent;">
                                                                    No puedes continuar debido a que tu vehículo actual
                                                                    ya tiene una cita asignada.</div>

                                                            </div>
                                                            <br></br>

                                                            <aura:if
                                                                isTrue="{! v.vehicleSelected =='Vehículo Propio' || v.vehicleSelected =='Vehículo de alguien más' }">

                                                                <div class="row">
                                                                    <div class="col-md-12" id="estimatedKM"
                                                                        style="margin:0;display:none">

                                                                        <lightning:input aura:id="inputKm" type="number"
                                                                            messageWhenBadInput="Debes ingresar únicamente valores numéricos"
                                                                            messageWhenValueMissing="Debes completar este campo para continuar"
                                                                            class="form-control-custom form-control paddingText"
                                                                            label="Ingrese el km de su vehículo:"
                                                                            value="{!v.estimatedKM}"
                                                                            placeholder="Ingrese el km de su vehículo"
                                                                            onchange="{! c.handleOnChangeEstimatedKM }" />
                                                                    </div>
                                                                </div>
                                                            </aura:if>
                                                            <aura:if isTrue="{!v.estimatedKM != ''}">

                                                                <div class="col-md-4" id="verifyCalendarButton">
                                                                    <lightning:button variant="brand"
                                                                        label="Verificar espacios" title="Brand action"
                                                                        onclick="{! c.handleVerifyCalendar}"
                                                                        class="btn btn-primary me-1 form-control" />
                                                                </div>

                                                            </aura:if>
                                                        </div>
                                                    </div>

                                                    <div id="alertExistingCitation"
                                                        style="display:none; padding:0 50px 40px;">
                                                        <!-- <p>Estimado(a):</p> <p>Usted ya cuenta con una reservación:</p> <p> Vehículo placa: <b> <ui:outputText value="{!v.eventCarId}" /> </b> </p> <p> Fecha y Hora: <b> <ui:outputText value="{!v.eventStartDate}" /> </b> </p> <p> Ubicación y tipo de servicio: <b> <ui:outputText value="{!v.eventLocation}" /> </b> </p> <lightning:button class="cancelButton" variant="destructive" label="Cancelar cita" title="Cancelar cita" onclick="{! c.cancelCurrentCitation }" />-->
                                                    </div>

                                                    <!-- Modals here-->

                                                    <div class="slds-m-around_xx-large">
                                                        <aura:if isTrue="{!v.isModalNewCase}">

                                                            <!-- Modal/Popup Box starts here-->
