                                                                                style="top:0 !important;right:-0.3rem !important "
                                                                                class="slds-button slds-button_icon slds-modal__close"
                                                                                title="Close"
                                                                                onclick="{!c.closeModelCase}">
                                                                                X
                                                                            </button>
                                                                            <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                                                                            <br />
                                                                            <p><b>. </b>

                                                                            </p>

                                                                            <lightning:input type="textarea"
                                                                                label="¿En que podemos ayudarle?"
