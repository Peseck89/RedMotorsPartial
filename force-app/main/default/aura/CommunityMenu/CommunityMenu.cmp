                                                                            <span style="margin-top: 30px;"
                                                                                class="citation-message"> Asistencia en
                                                                                línea. </span>
                                                                            <br />


                                                                            <button type="button"
                                                                                style="background-color: #25d366 !important; margin-top:15px"
                                                                                class="btn btn-success"><a
                                                                                    style="color:#ffffff !important;"
                                                                                    href="https://api.whatsapp.com/send?phone=50687954888&amp;text=Soporte%20Modulo%20de%20Autogestión"
                                                                                    target="_blank">WhatsApp</a></button>
                                                                            <br />
                                                                        </div>
                                                                        <br />
                                                                        <div id="creandocita2_" style="padding-top:2px">
                                                                        </div>

                                                                    </header>

                                                                </div>
                                                            </section>
                                                            <div class="slds-backdrop slds-backdrop_open"></div>
                                                        </aura:if>
                                                    </div>


                                                    <div class="slds-m-around_xx-large">
                                                        <aura:if isTrue="{!v.isModalOpenExistingCitation}">

                                                            <!-- Modal/Popup Box starts here-->
                                                            <section role="dialog" tabindex="-1"
                                                                aria-labelledby="modal-heading-01" aria-modal="true"
                                                                aria-describedby="modal-content-id-1"
                                                                class="slds-modal slds-fade-in-open">
                                                                <div class="slds-modal__container">
                                                                    <!-- Modal/Popup Box Header Starts here-->
                                                                    <header class="slds-modal__header">
                                                                        <lightning:buttonIcon iconName="utility:close"
                                                                            onclick="{! c.closeModel }"
                                                                            alternativeText="close"
                                                                            variant="bare-inverse"
                                                                            class="slds-modal__close" />

                                                                        <!--Modal/Popup Box Body Starts here-->
                                                                        <p class="p-mobile">Estimado(a):</p>
                                                                        <p class="p-mobile-single">Usted ya cuenta con
                                                                            una reservación:</p>
                                                                        <p class="p-mobile-single">Vehículo placa: <b>
                                                                                <ui:outputText
                                                                                    value="{!v.eventCarId}" />
                                                                            </b></p>
                                                                        <p class="p-mobile-single">Fecha y Hora: <b>
                                                                                <ui:outputText
                                                                                    value="{!v.eventStartDate}" />
                                                                            </b></p>
                                                                        <p class="p-mobile-single">
                                                                            Ubicación y tipo de servicio:
                                                                            <b>
                                                                                <ui:outputText
                                                                                    value="{!v.eventLocation}" />
                                                                            </b>
                                                                        </p>
                                                                        <br />
                                                                        <br />
                                                                        <lightning:button variant="neutral"
                                                                            label="Volver" title="Volver"
                                                                            onclick="{! c.closeModel }" />
                                                                        <lightning:button class="cancelButton"
                                                                            variant="destructive" label="Cancelar cita"
                                                                            title="Cancelar cita"
                                                                            onclick="{! c.cancelCurrentCitation }" />


                                                                    </header>

                                                                </div>
                                                            </section>
                                                            <div class="slds-backdrop slds-backdrop_open"></div>
                                                        </aura:if>
                                                    </div>

                                                    <div class="slds-m-around_xx-large"
                                                        id="confirmationOfCancelledCitation" style="display:none">


                                                        <!-- Modal/Popup Box starts here-->
                                                        <section role="dialog" tabindex="-1"
                                                            aria-labelledby="modal-heading-01" aria-modal="true"
                                                            aria-describedby="modal-content-id-1"
                                                            class="slds-modal slds-fade-in-open">
                                                            <div class="slds-modal__container">
                                                                <!-- Modal/Popup Box Header Starts here-->
                                                                <header class="slds-modal__header">

