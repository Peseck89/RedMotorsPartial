                                                                                                name="{!questionIndex.Numero_de_pregunta__c}"
                                                                                                messageWhenValueMissing="Debes completar este campo para continuar"
                                                                                                class="form-control-custom form-control desktop-form-control"
                                                                                                label="{! questionIndex.Pregunta__c + ':' }"
                                                                                                value="" required="true"
                                                                                                placeholder="Respuesta"
                                                                                                onchange="{! c.handleOnChange }" />
