                                                    <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                                                        <div class="desktop"
                                                            style="margin: auto; width: 100%; padding: 0px; box-shadow: 1px 1px 6px grey;">
                                                            <img src="{!$Resource.encabezadoMotos}" alt="BMWHeader" />
                                                        </div>
                                                    </aura:if>

                                                    <div class="testJD" id="testJD" style="display:none; ">

                                                        <div class="slds-m-around_xx-large">
                                                            <aura:if isTrue="{!v.isModalOpenConfirmation}">
