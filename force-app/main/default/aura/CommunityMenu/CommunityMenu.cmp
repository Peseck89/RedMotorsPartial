                                                    <!-- CALENDARIO -->
                                                    <div id="container" style="display:none">
                                                        <div id="containerCalendario" class="">
                                                            <div class="calendar-header">
                                                                <a class="prev-button" id="prev">
                                                                    <i class="material-icons">keyboard_arrow_left
                                                                    </i>
                                                                </a>
                                                                <a class="next-button" id="next">
                                                                    <i class="material-icons">keyboard_arrow_right
                                                                    </i>
                                                                </a>
                                                                <div class="row header-title">
                                                                    <div class="header-text">
                                                                        <h3 id="month-name">February</h3>
                                                                        <h5 id="todayDayName">
                                                                            Today is Friday 7 Feb
                                                                        </h5>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>

                                                        <div class="">
                                                            <div class="calendar-content">
                                                                <div id="calendar-table" class="calendar-cells">
                                                                    <div id="table-header">
                                                                        <div class="row">
                                                                            <div class="col">Mon</div>
                                                                            <div class="col">Tue</div>
                                                                            <div class="col">Wed</div>
                                                                            <div class="col">Thu</div>
                                                                            <div class="col">Fri</div>
                                                                            <div class="col">Sat</div>
                                                                            <div class="col">Sun</div>
                                                                        </div>
                                                                    </div>
                                                                    <div id="table-body" class=""></div>
                                                                </div>
                                                            </div>
                                                            <div class="popup" id="testToggle" style="">
                                                                <span class="popuptext" id="myPopup">
                                                                    <lightning:button variant="base" label="Continuar"
                                                                        title="Continuar" onclick="{! c.myTest }" />
                                                                </span>
                                                            </div>
                                                            <br />
                                                            <br />
                                                            <br />
                                                            <div class="fixed" id="sidebarMovil"
                                                                style="display:none;background-color: white;text-align:center">
                                                                <div class="" style="padding-bottom:40px;">
                                                                    <lightning:button variant="brand"
                                                                        label="Reservacion tentativa conforme a la disponibilidad de la movil"
                                                                        title="Reservacion tentativa conforme a la disponibilidad de la movil"
                                                                        onclick="{! c.nuevaCitaMovil }" />
                                                                </div>
                                                            </div>
                                                            <div class="fixed" id="sidebar" style="display:none">
                                                                <div class="sidebar-title">
                                                                    <h4 id="eventDayName" class="month-name">
                                                                        Date
                                                                    </h4>

                                                                    <h5 id="sidebar-texttitle"
                                                                        class="available-Citations">
                                                                        Citas Disponibles: 0

                                                                    </h5>
                                                                </div>
                                                                <div class="container">
                                                                    <div class="sidebar-events row" id="sidebarEvents">

                                                                    </div>
                                                                    <div class="empty-message">
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>



                                                    <div class="calendar-footer" style="display:none">
                                                        <div class="emptyForm" id="emptyForm">
                                                            <h4 id="emptyFormTitle">No events now</h4>
                                                            <a class="addEvent" id="changeFormButton">Add new
                                                            </a>
                                                        </div>
                                                        <div class="addForm" id="addForm">
                                                            <h4>Add new event</h4>
                                                            <div class="row">
                                                                <div class="input-field col s6">
                                                                    <input id="eventTitleInput" type="text"
                                                                        class="validate" />
                                                                    <label for="eventTitleInput">Title </label>
                                                                </div>
                                                                <div class="input-field col s6">
                                                                    <input id="eventDescInput" type="text"
                                                                        class="validate" />
                                                                    <label for="eventDescInput">Description
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <div class="addEventButtons">
                                                                <a class="waves-effect waves-light btn blue lighten-2"
                                                                    id="addEventButton">Add
                                                                </a>
                                                                <a class="waves-effect waves-light btn grey lighten-2"
                                                                    id="cancelAdd">Cancel
                                                                </a>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <!--Aquí va lo de JD-->
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- / Content -->
                        </div>
                        <!-- Footer -->
                        <!-- <footer class="content-footer footer bg-footer-theme">
                            <div
                                class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">

                                <a class="mb-2 mb-md-0" onclick="{! c.mostrarTerminos }">Politica de Confidencialidad y Proteccion de Datos</a>
                                <div class="mb-2 mb-md-0">
                                    © 2025. Comunidad RedMotors. By PortalNet.
                                </div>
                                <div></div>
                            </div>
                        </footer> -->
                        <footer class="content-footer footer bg-footer-theme">
                            <div class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">
                              <div><a onclick="{! c.mostrarTerminos }">Politica de Confidencialidad y Proteccion de Datos</a></div>
                              <div class="mb-2 mb-md-0">
                                © 2025. Comunidad RedMotors. By PortalNet.
                              </div>
                            </div>
                          </footer>
                        <!-- / Footer -->
                        <div class="content-backdrop fade"></div>
                    </div>
                    <!-- Content wrapper -->
                </div>
                <!-- / Layout page -->
            </div>
            <!-- Overlay -->
            <div id="overlayMenu" onclick="{! c.hideMenu }" class="layout-overlay layout-menu-toggle"></div>
            <!-- Core JS -->
            <!-- build:js assets/vendor/js/core.js -->
            <!-- endbuild -->
            <!-- Vendors JS -->
            <!-- Main JS -->
        </aura:if>
