                                                                <header class="slds-modal__header">
                                                                    
                                                                    <div id="creandocita3_" style="padding-top:2px">
                                                                        <ui:message title="Tu cita ha sido creada." severity="confirm" closable="false">Tu cita ha sido creada.</ui:message>
                                                                        <p><b>Lugar:  </b>
                                                                            <ui:outputText value="{!v.serviceCenterSelectedName}" />
                                                                        </p>
