<aura:component implements="force:hasRecordId,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes" access="global" controller="CommunityCalendarController">
  <aura:handler name="init" value="this" action="{!c.init}" />
    
  <!-- Contact Information -->
  <aura:attribute name="userInfo" type="user" />
  <aura:attribute name="vehiculoId" type="String" />
  <aura:attribute name="userId" type="String" />
  
  <aura:attribute name="motivoBaja" type="String" />
  <aura:attribute name="descripcionCase" type="String" />
  <aura:attribute name="isModalNewCase" type="Boolean" default="false"/>
  
  <!-- Nuevo coche Info -->
  <aura:attribute name="optionsTipo" type="List" default="[
  {'label': 'Automovil', 'value': 'Automovil'},
  {'label': 'Motocicleta', 'value': 'Motocicleta'}
  ]"/>
  <aura:attribute name="vinVehiculo" type="String" />
  <aura:attribute name="codModelo" type="String" />
  <aura:attribute name="matricula" type="String" />
  <aura:attribute name="marca" type="String" />
  <aura:attribute name="vehiculoTipo" type="String" />
<!-- Next User Citations - Information -->
  <aura:attribute name="userEvents" type="List" />
    <aura:attribute name="marcaSelected" type="String" default="BMW" />
    <aura:attribute name="data" type="Object"/>
    <aura:attribute name="columns" type="List"/>
    <aura:attribute name="isModalOpenSoporte" type="Boolean" default="false"/>
    <aura:attribute name="url" type="String"/>
    
    <aura:attribute name="isLoading" type="Boolean" default="false"/>
  <aura:method name="logParam" description="Sample method with parameter"> <aura:attribute name="message" type="String" default="default message" /></aura:method>
  <html lang="en" class="light-style layout-menu-fixed">
    <!--Community Calendar Components -->
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=yes"/>

      <!-- CSS -->
    <ltng:require styles="{!$Resource.CommunityCalendarStyle}" />				<!-- Nuestros CSSs -->
    <ltng:require styles="{!$Resource.CommunityCalendarStyleComplement}" />		<!-- Nuestros CSSs -->
    <ltng:require styles="{!$Resource.CustomerCommunitiesAdditionalStyles}" />	<!-- Nuestros CSSs -->
      
    <ltng:require styles="{!$Resource.CustomerCommunity_corecss}" />													<!-- Template CSSs -->
    <ltng:require styles="{!$Resource.CustomerCommunity_themeDefault}" />												<!-- Template CSSs -->
    <ltng:require styles="{!$Resource.CustomerCommunityFiles + 'CustomerCommunity/assets/vendor/fonts/boxicons.css'}"/>	<!-- Template CSSs -->
    
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0"/>
      <title> </title>
      <meta name="description" content="" />
      <!-- Fonts -->
    </head>
    <body>
      <aura:if isTrue="{!v.isLoading}">
            <!-- Add your spinner markup or use Salesforce's spinner component here -->
            <!-- For example, you can use SLDS (Salesforce Lightning Design System) spinner -->
            <div class="spinner-container" style="background-color: rgba(0, 0, 0, 0.9);top: 0;left: 0;position:fixed;width: 100%;height: 100%; align-items: center;justify-content: center;z-index: 9999;">
                <div class="slds-spinner slds-spinner_medium">
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
            </div>
        </aura:if>
      <!-- Layout wrapper -->
      <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">
          <!-- Menu -->
          <aside
            id="layout-menu"
            class="layout-menu menu-vertical menu bg-menu-theme"
          >
            <div class="app-brand demo">
              <a class="app-brand-link">
                <a class="app-brand-link">
                  <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                      <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                  </aura:if>
                  <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                      <img src="{!$Resource.communityMINI}" alt="BMWLogo" style="max-width: 175px;" />
                  </aura:if>
                  <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                      <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                  </aura:if>
                </a>
              </a>
              <a class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none" > <i class="bx bx-chevron-left bx-sm align-middle"> </i> </a>
            </div>
            <div class="menu-inner-shadow"></div>
            <ul class="menu-inner py-1">
              <!-- Dashboard -->
                        <!-- <li class="menu-item">
                            <a class="menu-link">
                                <i class="menu-icon tf-icons bx bx-home-circle"> </i>
                                <div data-i18n="Analytics">Próximamente</div>
                            </a>
                        </li> -->
                        <li class="menu-header small text-uppercase">
                          <span class="menu-header-text">Gestión de Citas </span>
                      </li>
                      <li class="menu-item">
                        <a class="menu-link menu-toggle " href="{!'/s/?servicio=' + v.marcaSelected}">
                        <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                        <div class="under" data-i18n="Authentications">Nueva Cita</div>
                      </a>
                        <ul class="menu-sub"></ul>
                      </li>
                      <li class="menu-item">
                        <a class="menu-link menu-toggle" href="{!'/s/communitycancelappointments?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                            <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                            <div class="under" data-i18n="Authentications">Modificar Cita</div>
                        </a>
                        <ul class="menu-sub"></ul>
                    </li>
                    <li class="menu-item">
                        <a class="menu-link menu-toggle" href="{!'/s/communityappointmentshistory?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                            <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                            <div class="under" data-i18n="Authentications">Historial de Citas</div>
                        </a>
                        <ul class="menu-sub"></ul>
                    </li>
                      <li class="menu-item">
                        <a class="menu-link menu-toggle"  onclick="{! c.openSoporte }">
                            <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                            <div data-i18n="Authentications">Asistencia en Linea</div>
                        </a>
                        <ul class="menu-sub"></ul>
                      </li>
                      <li class="menu-item">
                        <a class="menu-link menu-toggle" href="{!'/s/gestionavehiculos?id=' + v.contactId+ '&amp;marca=' +  v.marcaSelected}">
                            <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                            <div class="under active" data-i18n="Authentications">Gestiona tus vehiculos</div>
                        </a>
                        <ul class="menu-sub"></ul>
                    </li>
                      <!-- Components -->
                      <li class="menu-header small text-uppercase">
                          <span class="menu-header-text">Mi Perfil </span>
                      </li>
                      <!-- Cards -->
                      <li class="menu-item">
                          <a class="menu-link">
                              <i class="menu-icon tf-icons bx bx-collection"> </i>
                              <div class="under" data-i18n="Basic">Próximamente</div>
                          </a>
                      </li>
                      <li class="menu-item">
                        <a class="menu-link" href="/secur/logout.jsp">
                            <i class="menu-icon tf-icons bx bx-collection"> </i>
                            <div class="under" data-i18n="Basic">LogOut</div>
                        </a>
                    </li>
                  </ul>
          </aside>
          <!-- / Menu -->
          <!-- Layout container -->
          <div class="layout-page">
            <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme" id="layout-navbar">
              <div class="app-brand demo logo-mobile">
                  <a class="app-brand-link">
                      <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                          <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                      </aura:if>
                      <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                          <img src="{!$Resource.communityMINI}" alt="BMWLogo" style="max-width: 175px;" />
                      </aura:if>
                      <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                          <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                      </aura:if>
                  </a>
              </div>
              <div class=" layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
                  <a class="nav-item nav-link px-0 me-xl-4">
                      <i class="bx bx-menu bx-sm"> </i>
                  </a>
              </div>
              <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
                  <!-- /Search -->
                  <ul class="navbar-nav flex-row align-items-center ms-auto">
                      <!-- Place this tag where you want the button to render. -->
                      <li class="nav-item lh-1 me-3 welcome-text">
                          <span>
                              <ui:outputText value="{!v.userName}" />
                          </span>
                      </li>
                  </ul>
                  <!-- Search -->
                  <div class=" hamburguesa navbar-nav align-items-center">
                      <div id="barMenu" onclick="{! c.showMenu }" style=" top:0;left:0;">
                          <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                          <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                          <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                      </div>
                      <div class="nav-item d-flex align-items-center"></div>
                  </div>
              </div>
            </nav>


            <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                <img src="{!$Resource.BMWCar}" alt="BMWLogo" class="banner-image"/>
            </aura:if>
            <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                <img src="{!$Resource.MINICar}" alt="BMWLogo" class="banner-image"/>
            </aura:if>
            <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                <img src="{!$Resource.MotoCar}" alt="BMWLogo" class="banner-image"/>
            </aura:if>
            
            
            
            <!-- Content wrapper -->
            <div class="content-wrapper">
              <!-- Content -->
              <div class="container-xxl flex-grow-1 container-p-y">
                <div id="barMenu" class="hamburguesa" onclick="{! c.showMenu }" style=" top:0;left:0;">
                  <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
                  <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
                  <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
              </div>
                <h4 class="fw-bold py-3 mb-4 second margin cancelMargin">Gestiona tus vehiculos.</h4>
                <div class="row">
                  <div class="col-12">
                    <div class="card-2 mb-4">
                      <div class="card-body">

                        <!-- Aquí va información sobre historial de transacciones-->
                          
                          <div class="table-responsive text-nowrap">
                  <table class="table">
                    <thead class="desktop">
                      <tr class="text-nowrap">
                        <th>Vehículo</th>
                        <th><button class="btn cambiarMarca btn-primary btn-block asign-button new-asign" onclick="{! c.openAlta }"> Nueva asignación </button></th>                        
                      </tr>
                    </thead>
                    <tbody id="dataRows">

                    </tbody>
                  </table>
                </div>

                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <!-- / Content -->
            </div>

            <div class="slds-m-around_xx-large" id="modalMens" style="display:none">
            <!-- Modal/Popup Box starts here-->
        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
            <div class="slds-modal__container">
                <!-- Modal/Popup Box Header Starts here-->
                <header class="slds-modal__header">
                   
                    <div id="creandocita1_">
                        <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.reload}">
                            X
                        </button>
                        <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                         <br />
                         <p><b>El vehiculo sera desasociado de su cuenta.</b></p>
                         <br />              
                           <lightning:textarea name="inputMotivo" value="{!v.motivoBaja}" label="Motivo:" />
                        
                        
                        <input type="text" id="vehiculoId" value="{!v.vehiculoId}" style="display: none;" />
                        
                        <br/> 
                    </div>
                    <br/>
                    <div id="creandocita2_" style="padding-top:2px">
                        <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.reload }" /> 
                        <lightning:button variant="destructive" label="Confirmar" title="Confirmar" onclick="{!c.removerVehiculo}" />        
                    </div>
                    
                </header>

            </div>
        </section>
        <div class="slds-backdrop slds-backdrop_open"></div>
        </div>


        <div class="slds-m-around_xx-large" id="modalAlta" style="display:none">
          <!-- Modal/Popup Box starts here-->
      <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
          <div class="slds-modal__container">
              <!-- Modal/Popup Box Header Starts here-->
              <header class="slds-modal__header asign-popup-container">
                 
                <div class="asign-popup-body" style="text-align: left;font-size: 12px !important; height: 350px;">
                      <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.reload}">
                          X
                      </button>
                      <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                       <br />
                       <p class="asign-popup-title"><b>Por favor ayudenos con la siguiente información para dar de alta su vehiculo.</b></p>
                       <br />
                                                                  
                      <br/> 
                  
                    <lightning:input class="matricula-container" name="matricula" value="{!v.matricula}" label="Matricula" required="true" />
                                                                    
                   </div> 
                  <br/>
                  <div id="creandocita2_" style="padding-top:2px">
                      <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.reload }" /> 
                      <lightning:button variant="brand" label="Confirmar" title="Confirmar" onclick="{!c.asignarNuevo}" />        
                  </div>
                  
              </header>

          </div>
      </section>
      <div class="slds-backdrop slds-backdrop_open"></div>
      </div>


        <div class="slds-m-around_xx-large" id="modalConfirm" style="display:none">
              <!-- Modal/Popup Box starts here-->
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
              <div class="slds-modal__container">
                  <!-- Modal/Popup Box Header Starts here-->
                  <header class="slds-modal__header">
                    
                      <div id="creandocita1_">
                          <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.reload}">
                              X
                          </button>
                          <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                          <br />
                          <p><b>Se solicitud ha sido enviada para su atención.</b></p>
                          <br />                                                      
                         
                          
                          <!-- <input type="text" id="eventoId" value="{!v.vehiculoId}" style="display: none;" /> -->
                          
                          <br/> 
                      </div>
                      <br/>
                      <div id="creandocita2_" style="padding-top:2px">
                          <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.reload }" /> 
                          <!-- <lightning:button variant="destructive" label="Confirmar" title="Confirmar" onclick="{!c.removerVehiculo}" />         -->
                      </div>
                      
                  </header>

              </div>
              </section>
              <div class="slds-backdrop slds-backdrop_open"></div>
          </div>


            <div class="slds-m-around_xx-large">
              <aura:if isTrue="{!v.isModalOpenSoporte}">

                  <!-- Modal/Popup Box starts here-->
                  <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                      <div class="slds-modal__container">
                          <!-- Modal/Popup Box Header Starts here-->
                          <header class="slds-modal__header">
                       
                            <div id="">
                                <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.closeSoporte}">
                                    X
                                </button>
                                <!--title="Asistencia en línea." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                                <br />
                                <span style="margin-top: 30px;" class="citation-message"> Asistencia en línea. </span>
                                 <br />
                               
                                 <button type="button" style="background-color: #25d366 !important;" class="btn btn-success"><a style="color:#ffffff !important;" href="https://api.whatsapp.com/send?phone=50687954888&amp;text=Soporte%20Modulo%20de%20Autogesti%C3%B3n" target="_blank">WhatsApp</a></button>                                                  
                                <br/> 
                            </div>
                            <br/>
                            <div id="creandocita2_" style="padding-top:2px">
                            </div>
                            
                        </header>

                      </div>
                  </section>
                  <div class="slds-backdrop slds-backdrop_open"></div>
              </aura:if>
          </div>
          <div class="slds-m-around_xx-large" id="terminosYcondiciones" style="display:none">
                                   
            <!-- Modal/Popup Box starts here-->
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <!-- Modal/Popup Box Header Starts here-->
                    <header class="slds-modal__header">
                        
                        <div class="terms-container" style="padding-top:2px">
                            <div style="height: 300px; overflow: scroll;">
                                <p><strong>TÉRMINOS Y CONDICIONES CITAS EN LINEA / ONLINE APPOINTMENT TERMS AND CONDITIONS</strong></p>

                                <p><strong>1. Los Servicios / Services:</strong></p>
                                <p>Los productos y servicios, en adelante denominados los "Servicios," se proporcionan a través de Red Motors S.A o cualquiera de sus empresas subsidiarias que formen parte del mismo grupo de interés económico mediante nuestras plataformas digitales en adelante denominado como “La plataforma.” El uso de nuestros Servicios implica la aceptación de estas condiciones. Por favor, lea y revise atentamente los Términos y Condiciones de uso y nuestra Política de Privacidad antes de utilizar cualquier Servicio en línea de Red Motors S.A. Si no está de acuerdo con estas condiciones, no podrá agendar citas para utilizar nuestros servicios.</p>
                            
                                <p><strong>2. La Plataforma / The Platform:</strong></p>
                                <p>La plataforma brinda distintos Servicios a personas físicas y/o jurídicas, en adelante denominadas “Usuario.” Por Usuario deberá entenderse cualquier persona que emplea los servicios o productos de la plataforma. Red Motors S.A se reserva el derecho de realizar modificaciones a estos términos y condiciones, y será su responsabilidad mantenerse informado al respecto.</p>
                            
                                <p><strong>3. Términos y Condiciones de la Plataforma SimplyBook / SimplyBook Platform Terms and Conditions:</strong></p>
                                <p>Utilizamos SimplyBook como plataforma de reservas, con lo que también aceptamos los términos y condiciones de la plataforma <a href="https://simplybook.me/en/terms-and-conditions#tab-for-clients" target="_blank">SimplyBook Terms and Conditions</a>. Para aclarar cualquier consulta relacionada con este tema, favor enviarnos un email a servicioalclientebmw@redmotorscr.com.</p>
                            
                                <p><strong>4. Contenido y Derechos de Propiedad Intelectual / Content and Intellectual Property Rights:</strong></p>
                                <p>Las fotografías de los productos muestran sus colores reales, sin embargo, el usuario puede verlos diferente según la calibración de su monitor. Por lo tanto, no podemos garantizar que los colores de los artículos sean idénticos a los mostrados en tu pantalla. Es indispensable que el usuario lea detenidamente la descripción del artículo antes de proceder con la compra.</p>
                            
                                <p>En el caso de que un usuario postee o envíe cualquier contenido a nuestro sitio web o a nuestras redes sociales, estaría permitiendo a Red Motors S.A. utilizar dicho material de manera gratuita, en la forma que considere conveniente; cediendo así cualquier derecho de imagen y/o audio/texto que en él aparezca. Además, el usuario garantiza que dicho contenido es de su propiedad o bien que cuenta con los derechos de uso de este. Red Motors S.A., podrá editar o eliminar a su discreción, cualquier contenido o actividad posteada por el usuario. Todo el contenido del sitio web es propiedad de Red Motors S.A.</p>
                            
                                <p><strong>5. Política de Cambios / Change Policy:</strong></p>
                                <p>Una vez agendada la cita, si desea cambiarla o cancelarla agradecemos comunicarse con nosotros al 2547-5000 a la brevedad para poderle atender.</p>
                                <p>Los servicios de diagnóstico serán atendidos solamente en la sucursal de Red Motors S.A de La Uruca, estos servicios se refieren a:</p>
                                <ul>
                                    <li>Revisar fugas de Aceite</li>
                                    <li>Revisar vibraciones o Sonidos en Carrocería; Sonidos de Suspensión; Sonidos en el Motor.</li>
                                    <li>Calentamiento en el Motor</li>
                                    <li>Diagnóstico de problemas en A/C</li>
                                    <li>Diagnóstico de Motores</li>
                                    <li>Diagnósticos para RTV</li>
                                    <li>Diagnóstico de Sistema Eléctrico</li>
                                    <li>Reparaciones mayores del Motor</li>
                                    <li>Revisión de luces encendidas en el panel.</li>
                                </ul>
                            </div>
                            <br />
                            <lightning:button variant="brand" label="Aceptar" title="Aceptar" onclick="{! c.closeModalTerminos }" />
                        </div>
                    </header>

                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
       
        </div>
            <div class="slds-m-around_xx-large">
              <aura:if isTrue="{!v.isModalNewCase}">

                  <!-- Modal/Popup Box starts here-->
                  <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                      <div class="slds-modal__container">
                          <!-- Modal/Popup Box Header Starts here-->
                          <header class="slds-modal__header">
         
                              <div id="">
                                  <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.closeModelCase}">
                                      X
                                  </button>
                                  <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                                   <br />
                                  <p><b>.  </b>
                                     
                                  </p>
                                  
                                  <lightning:input type="textarea" label="¿En que podemos ayudarle?" value="{!v.descripcionCase}" />
                                  
                                  <br/> 
                              </div>
                              <br/>
                              <div id="creandocita2_" style="padding-top:2px">
                                  <lightning:button variant="brand" label="Confirmar" title="Confirmar" onclick="{!c.createCase}" />        
                              </div>
                              
                          </header>

                      </div>
                  </section>
                  <div class="slds-backdrop slds-backdrop_open"></div>
              </aura:if>
          </div> 


            <!-- Footer -->
            <footer class="content-footer footer bg-footer-theme">
              <div
                class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column"
              >
              <div class="mb-2 mb-md-0">
                © 2023. Comunidad RedMotors. By PortalNet.
            </div>
            <div><a onclick="{! c.mostrarTerminos }">Terminos y condiciones</a></div>
              </div>
            </footer>
            <!-- / Footer -->
            <div class="content-backdrop fade"></div>
          </div>
          <!-- Content wrapper -->
        </div>
        <!-- / Layout page -->
      </div>
      <!-- Overlay -->
      <div id="overlayMenu" onclick="{! c.hideMenu }" class="layout-overlay layout-menu-toggle"></div>
      <!-- Core JS -->
      <!-- build:js assets/vendor/js/core.js -->
      <!-- endbuild -->
      <!-- Vendors JS -->
      <!-- Main JS -->
      <button class="floating-button desktop" style="position: fixed;bottom: -1px;right: 20px;z-index: 999; border-radius: 50%;background-color:transparent;border-color:transparent;  padding: 10px;" onclick="{!c.openModalCase}">        
        <!-- <lightning:icon iconName="standard:service_crew" size="large" alternativeText="Support Icon" /> -->
        <div class="main-div" style="width: 300px;height: 50px;">
            <div class="blue-circle" style="display: flex;height: 50px;width: 50px;background-color: white;border-radius: 50%;position: absolute;left: 5px;z-index: 999;">
              <div class="text-div" style="top: 9%;left: 10%;background-color:white;height: 40px;width: 40px;position: absolute;border-radius:50px;height: 40px;width: 40px;background-position:center;" ><img src="{!$Resource.chatImage}" alt="Italian Trulli"/></div>
            </div>
            <div class="black-side" style="display: flex;justify-content: center;align-items: center;width: 100%;height: 40%;top: 0;position: absolute;background-color: black;color: white;border-top-left-radius: 5px;border-top-right-radius: 5px;font-weight: bold;">
                <p>BMW</p>
            </div>
            <div class="gray-side" style="display: flex;justify-content: center;align-items: center;width: 100%;height: 60%;bottom: 0;position: absolute;background-color: white;border-style: outset;border-bottom-left-radius: 5px;border-bottom-right-radius: 5px;font-weight: bold;">
                <p>¿Tienes dudas?</p>
            </div>
        </div>
      </button>
      <button class="floating-button mobile" style="position: fixed;z-index: 999;bottom: 25px;right: 20px;border-radius: 15px;background-color:transparent;border-color: transparent; width:85px" onclick="{!c.openModalCase}">        
        <div>
            <div class="cons-container">
                <p>Consultas</p>
            </div>
            <div class="bottom-container">
                <img src="{!$Resource.chatImage}" alt="Italian Trulli"/>
            </div>
        </div>
    </button>
    </body>
  </html>
</aura:component>