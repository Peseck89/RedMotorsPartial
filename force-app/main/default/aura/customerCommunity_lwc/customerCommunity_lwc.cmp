                        <!-- Modals -->

                                                <div class="container">
                                                    <div class="row row-header-custom" id="verificarSection">

                                                        <div class="row">
                                                            <div class="col-md-12">
                                                                <lightning:combobox class="start-select"  label="Seleccione el servicio: " aura:id="options"  name="options" placeholder="{!v.Servicio}" options="{! v.optionsService }" onchange="{!c.handleOnChangeSelectedService}" value="{!v.selectedValue}" >
                                                                    
                                                                </lightning:combobox> 
                                                                
                                                            </div>
                                                        </div>
                                                        <!-- <div class="row"> -->
                                                            <!--<aura:if isTrue="{!v.serviceSelected == 'Mecánica Rápida'}">-->
                                                                <div class="additionalServices" id="additionalServices" style="display:none">
                                                                    <div class="sidebar-events" id ="additionalTableService" style="padding: 0px 0px 0px 0px;">                                                      
                                                                    </div>
                                                                    <!-- <ui:inputText class="paddingText"  label="Desea reportar un fallo" value="{!v.additionalComments}" updateOn="change" change="{!c.onChangeComment}" /> -->
                                                                    <div class="row additionalServices" id="seleccionVehiculo">
                                                                        <div class="col-md-12"  style="margin:0;">
                                                                            <lightning:combobox class="form-control" name="ownVehicule" label="Desea reportar un fallo: " placeholder="Desea reportar un fallo" options="{!v.optionsErrors}" id="userOptions" onchange="{!c.onChangeComment}" />
                                                                        </div>
                                                                    </div>
                                                                    
                                                                </div>
                                                            <!--</aura:if>-->
                                                            <div class ="errorMessage" id="errorMessage" style="display:none;">
                                                            <div style="background-color: #f8d7da;color: #721c24;font-size: 20px;border-color: #f5c6cb;border-radius: 4px; padding: 20px; border: 1px solid transparent;"> Para continuar, debes de seleccionar al menos un servicio o agregar un comentario.</div>
        
                                                        <!-- </div> -->
                                                        <br/>
                                                       
                                                        </div>
                                                        <div class="col-md-6" id="vehicleSelection" style="display:none">
                                                            <!-- <lightning:combobox class="form-control" name="vehicle" label="Seleccione el tipo de vehículo: " placeholder="Tipo Vehículo" options="{!v.optionsVehicule}" onchange="{! c.handleOnChangeVehiculeSelection }" /> -->
                                                        </div>
                                                            <div class="row additionalServices" id="seleccionVehiculo">
                                                            
                                                            <div class="col-md-12" id="ownVehicule" style="display:none;margin:0;">
                                                                <aura:if isTrue="{!v.hasNoAssets}">
                                                                    <ui:message title="Error." severity="Error" closable="false">No tienes vehículo asociado en esta marca, click <a onclick="{! c.mostrarCambiarMarca }">aquí</a>  para cambiar de marca.</ui:message>
                                                                    <aura:set attribute="else">
                                                                        <aura:if isTrue="{!v.vehicleSelected=='Vehículo Propio'}">
                                                                        <lightning:combobox class="form-control" name="ownVehicule" label="Seleccione vehículo: " placeholder="*En caso que su vehículo no esta asignado a su perfil por favor diríjase a Asistencia en línea" options="{!v.userAssets}" id="userAssets" onchange="{!c.handleOnOwnChange}" onclick="{!c.handleKMVisivility}" />
                                                                        </aura:if>
                                                                        </aura:set>
                                                                </aura:if>
                                                            </div>

                              
                                                            <div class="col-md-6" id="vehiculeId" style="display:none; margin:0;">
                                                                <lightning:input class="form-control-custom form-control" label="Ingrese la placa del vehículo " value="{!v.vehicleId}" placeholder="Placa" onchange="{! c.handleOnChangeVehiculeId }" />
                                                            </div>
                                                        </div>
                                                        
                                                        <div class="contenedorTablaFea" style="margin-bottom: 20px;">
                                                            <div id="vehicleInfo" class="row additionalServices tablaInteriorInfo" style="display:none;margin-left: 12px;width: 94%;margin-bottom:20px !important;"> 
                                                                <p class = "textoInformacion" style="font-size: 1.6rem">Información de su vehículo:</p>
                                                                <br/>
                                                                <table id="vehicleInfoTable"  class="textoInformacion" style="font-size:18px">
                                                                    <thead>
                                                                        <tr>
                                                                        <th style="width: 20%;">Marca</th>
                                                                        <th style="width: 20%;">Modelo</th>
                                                                        <th style="width: 20%;">Año</th>
                                                                        <th style="width: 20%;">Color</th>
                                                                        <th style="width: 20%;">Placa</th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                    </tbody>
                                                                    </table>
                                                            </div>
                                                        </div>
                                                        <div id="errorExistingCitation" style="display:none">
                                                            <div style="background-color: #f8d7da;color: #721c24;font-size: 20px;border-color: #f5c6cb;border-radius: 4px; padding: 15px; border: 1px solid transparent;">No puedes continuar debido a que tu vehículo actual ya tiene una cita asignada.</div>
                                                            
                                                        </div>
                                                        <br></br>
                                                        
                                                        <aura:if isTrue="{! v.vehicleSelected =='Vehículo Propio' || v.vehicleSelected =='Vehículo de alguien más' }">
                                                            
                                                            <div class="row">
                                                                <div class="col-md-12" id="estimatedKM" style="margin:0;display:none">

                                                                    <lightning:input aura:id="inputKm" type="number" messageWhenBadInput="Debes ingresar únicamente valores numéricos" messageWhenValueMissing="Debes completar este campo para continuar" class="form-control-custom form-control paddingText" label="Ingrese el km de su vehículo:" value="{!v.estimatedKM}" placeholder="Ingrese el km de su vehículo" onchange="{! c.handleOnChangeEstimatedKM }" />
                                                                </div>
                                                            </div>
                                                        </aura:if>
                                                        <aura:if isTrue="{!v.estimatedKM != ''}">
                                                            
                                                            <div class="col-md-4" id="verifyCalendarButton">
                                                            <lightning:button variant="brand" label="Verificar espacios" title="Brand action" onclick="{! c.handleVerifyCalendar}"  class="btn btn-primary me-1 form-control" />
                                                        </div>
                                                        
                                                        </aura:if>
                                                    </div>
                                                </div>

                                                <div id="alertExistingCitation" style="display:none; padding:0 50px 40px;">
                                                    <!-- <p>Estimado(a):</p> <p>Usted ya cuenta con una reservación:</p> <p> Vehículo placa: <b> <ui:outputText value="{!v.eventCarId}" /> </b> </p> <p> Fecha y Hora: <b> <ui:outputText value="{!v.eventStartDate}" /> </b> </p> <p> Ubicación y tipo de servicio: <b> <ui:outputText value="{!v.eventLocation}" /> </b> </p> <lightning:button class="cancelButton" variant="destructive" label="Cancelar cita" title="Cancelar cita" onclick="{! c.cancelCurrentCitation }" />-->
                                                </div>
                        
                        <!-- Modals here-->

                        <div class="slds-m-around_xx-large">
                            <aura:if isTrue="{!v.isModalNewCase}">

                                <!-- Modal/Popup Box starts here-->
                                <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                    <div class="slds-modal__container">
                                        <!-- Modal/Popup Box Header Starts here-->
                                        <header class="slds-modal__header">
                       
                                            <div id="">
                                                <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.closeModelCase}">
                                                    X
                                                </button>
                                                <!--title="Tu cita ha sido creada." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                                                 <br />
                                                <p><b>.  </b>
                                                   
                                                </p>
                                                
                                                <lightning:input type="textarea" label="¿En que podemos ayudarle?" class="slds-textarea" value="{!v.descripcionCase}" />
                                                
                                                <br/> 
                                            </div>
                                            <br/>
                                            <div id="creandocita2_" style="padding-top:2px">
                                                <lightning:button variant="brand" label="Confirmar" title="Confirmar" onclick="{!c.createCase}" />        
                                            </div>
                                            
                                        </header>

                                    </div>
                                </section>
                                <div class="slds-backdrop slds-backdrop_open"></div>
                            </aura:if>
                        </div>

                        <div class="slds-m-around_xx-large">
                            <aura:if isTrue="{!v.isModalOpenSoporte}">

                  <!-- Modal/Popup Box starts here-->
                  <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                      <div class="slds-modal__container">
                          <!-- Modal/Popup Box Header Starts here-->
                          <header class="slds-modal__header">
                       
                            <div id="">
                                <button style="top:0 !important;right:-0.3rem !important " class="slds-button slds-button_icon slds-modal__close" title="Close" onclick="{!c.closeSoporte}">
                                    X
                                </button>
                                <!--title="Asistencia en línea." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                                <br />
                                <span style="margin-top: 30px;" class="citation-message"> Asistencia en línea. </span>
                                 <br />
                                 
                                 
                                 <button type="button" style="background-color: #25d366 !important; margin-top:15px" class="btn btn-success"><a style="color:#ffffff !important;" href="https://api.whatsapp.com/send?phone=50687954888&amp;text=Soporte%20Modulo%20de%20Autogestión" target="_blank">WhatsApp</a></button>                                                  
                                <br/> 
                            </div>
                            <br/>
                            <div id="creandocita2_" style="padding-top:2px">
                            </div>
                            
                        </header>

                      </div>
                  </section>
                  <div class="slds-backdrop slds-backdrop_open"></div>
              </aura:if>
                        </div>


                                                <div class="slds-m-around_xx-large">
                                                    <aura:if isTrue="{!v.isModalOpenExistingCitation}">

                                                        <!-- Modal/Popup Box starts here-->
                                                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                                            <div class="slds-modal__container">
                                                                <!-- Modal/Popup Box Header Starts here-->
                                                                <header class="slds-modal__header">
                                                                    <lightning:buttonIcon iconName="utility:close" onclick="{! c.closeModel }" alternativeText="close" variant="bare-inverse" class="slds-modal__close" />

                                                                    <!--Modal/Popup Box Body Starts here-->
                                                                    <p class="p-mobile">Estimado(a):</p>
                                                                    <p class="p-mobile-single">Usted ya cuenta con una reservación:</p>
                                                                    <p class="p-mobile-single">Vehículo placa: <b>
                                                                            <ui:outputText value="{!v.eventCarId}" />
                                                                        </b></p>
                                                                    <p class="p-mobile-single">Fecha y Hora: <b>
                                                                            <ui:outputText value="{!v.eventStartDate}" />
                                                                        </b></p>
                                                                    <p class="p-mobile-single">
                                                                        Ubicación y tipo de servicio:
                                                                        <b>
                                                                            <ui:outputText value="{!v.eventLocation}" />
                                                                        </b>
                                                                    </p>
                                                                    <br/>
                                                                    <br/>
                                                                    <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.closeModel }" /> 
                                                                    <lightning:button class="cancelButton" variant="destructive" label="Cancelar cita" title="Cancelar cita" onclick="{! c.cancelCurrentCitation }" />


                                                                </header>

                                                            </div>
                                                        </section>
                                                        <div class="slds-backdrop slds-backdrop_open"></div>
                                                    </aura:if>
                                                </div>
                                                
                                                <div class="slds-m-around_xx-large" id="confirmationOfCancelledCitation" style="display:none">
                                   

                                                        <!-- Modal/Popup Box starts here-->
                                                        <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                                            <div class="slds-modal__container">
                                                                <!-- Modal/Popup Box Header Starts here-->
                                                                <header class="slds-modal__header">
                                                                    
                                                                    <div id="creandocita3_" class="cancel-appoinment">
                                                                        <ui:message class="cancel-appoinment" title="Tu cita ha sido cancelada." severity="confirm" closable="false">Tu cita ha sido cancelada correctamente.</ui:message>

                                                                        <lightning:button variant="brand" label="Reservar nueva cita" title="Reservar nueva cita" onclick="{! c.reload }" />
                                                                    </div>
                                                                </header>

                                                            </div>
                                                        </section>
                                                        <div class="slds-backdrop slds-backdrop_open"></div>
                                                   
                                                </div>

                                                <div id="vehiculeIdSoonEvent" style="display:none; padding:0 50px 40px;">
                                                    <p>Estimado(a):</p>
                                                    <p>
                                                        El vehículo seleccionado ya cuenta con una
                                                        reservación.
                                                    </p>
                                                    <p>
                                                        Por favor comuníquese con el dueño del vehículo o
                                                        con el equipo de soporte.
                                                    </p>
                                                    <p><b>Soporte:</b> +(506) XXXX-XXXX</p>
                                                </div>
                                                
                                                <!-- Modals here | End of Modals-->
                                                <div class="centroDeServicio" id="centroDeServicio" style="display:none">
                                                    <div class="header-text" style="margin-left: 74px;margin-bottom:15px">
                                                        <label style="font-size: 1.6rem;color:#262626;" >Seleccione Sucursal</label>                                                        
                                                    </div>                                                    
                                                    <br/>
                                                    <lightning:tabset onselect="{! c.handleChangeServiceCenter }" variant="scoped" selectedTabId="{!v.selTabId}" class="tabset">
                                                        <aura:iteration items="{! v.tabs }" var="tab">
                                                            <lightning:tab label="{! tab.label }" id="{! tab.id }">
                                                            </lightning:tab>
                                                        </aura:iteration>
                                                    </lightning:tabset>
                                                </div>

                                                
                                                <div class="slds-m-around_xx-large" id="terminosYcondiciones" style="display:none">
                                   
                                                    <!-- Modal/Popup Box starts here-->
                                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                                        <div class="slds-modal__container">
                                                            <!-- Modal/Popup Box Header Starts here-->
                                                            <header class="slds-modal__header">
                                                                
                                                                <div class="terms-container">
                                                                    <div style="height: 300px; overflow: scroll;">
                                                                        <p><strong>TÉRMINOS Y CONDICIONES CITAS EN LINEA / ONLINE APPOINTMENT TERMS AND CONDITIONS</strong></p>

                                                                        <p><strong>1. Los Servicios / Services:</strong></p>
                                                                        <p>Los productos y servicios, en adelante denominados los "Servicios," se proporcionan a través de Red Motors S.A o cualquiera de sus empresas subsidiarias que formen parte del mismo grupo de interés económico mediante nuestras plataformas digitales en adelante denominado como “La plataforma.” El uso de nuestros Servicios implica la aceptación de estas condiciones. Por favor, lea y revise atentamente los Términos y Condiciones de uso y nuestra Política de Privacidad antes de utilizar cualquier Servicio en línea de Red Motors S.A. Si no está de acuerdo con estas condiciones, no podrá agendar citas para utilizar nuestros servicios.</p>
                                                                    
                                                                        <p><strong>2. La Plataforma / The Platform:</strong></p>
                                                                        <p>La plataforma brinda distintos Servicios a personas físicas y/o jurídicas, en adelante denominadas “Usuario.” Por Usuario deberá entenderse cualquier persona que emplea los servicios o productos de la plataforma. Red Motors S.A se reserva el derecho de realizar modificaciones a estos términos y condiciones, y será su responsabilidad mantenerse informado al respecto.</p>
                                                                    
                                                                        <p><strong>3. Términos y Condiciones de la Plataforma SimplyBook / SimplyBook Platform Terms and Conditions:</strong></p>
                                                                        <p>Utilizamos SimplyBook como plataforma de reservas, con lo que también aceptamos los términos y condiciones de la plataforma <a href="https://simplybook.me/en/terms-and-conditions#tab-for-clients" target="_blank">SimplyBook Terms and Conditions</a>. Para aclarar cualquier consulta relacionada con este tema, favor enviarnos un email a servicioalclientebmw@redmotorscr.com.</p>
                                                                    
                                                                        <p><strong>4. Contenido y Derechos de Propiedad Intelectual / Content and Intellectual Property Rights:</strong></p>
                                                                        <p>Las fotografías de los productos muestran sus colores reales, sin embargo, el usuario puede verlos diferente según la calibración de su monitor. Por lo tanto, no podemos garantizar que los colores de los artículos sean idénticos a los mostrados en tu pantalla. Es indispensable que el usuario lea detenidamente la descripción del artículo antes de proceder con la compra.</p>
                                                                    
                                                                        <p>En el caso de que un usuario postee o envíe cualquier contenido a nuestro sitio web o a nuestras redes sociales, estaría permitiendo a Red Motors S.A. utilizar dicho material de manera gratuita, en la forma que considere conveniente; cediendo así cualquier derecho de imagen y/o audio/texto que en él aparezca. Además, el usuario garantiza que dicho contenido es de su propiedad o bien que cuenta con los derechos de uso de este. Red Motors S.A., podrá editar o eliminar a su discreción, cualquier contenido o actividad posteada por el usuario. Todo el contenido del sitio web es propiedad de Red Motors S.A.</p>
                                                                    
                                                                        <p><strong>5. Política de Cambios / Change Policy:</strong></p>
                                                                        <p>Una vez agendada la cita, si desea cambiarla o cancelarla agradecemos comunicarse con nosotros al 2547-5000 a la brevedad para poderle atender.</p>
                                                                        <p>Los servicios de diagnóstico serán atendidos solamente en la sucursal de Red Motors S.A de La Uruca, estos servicios se refieren a:</p>
                                                                        <ul>
                                                                            <li>Revisar fugas de Aceite</li>
                                                                            <li>Revisar vibraciones o Sonidos en Carrocería; Sonidos de Suspensión; Sonidos en el Motor.</li>
                                                                            <li>Calentamiento en el Motor</li>
                                                                            <li>Diagnóstico de problemas en A/C</li>
                                                                            <li>Diagnóstico de Motores</li>
                                                                            <li>Diagnósticos para RTV</li>
                                                                            <li>Diagnóstico de Sistema Eléctrico</li>
                                                                            <li>Reparaciones mayores del Motor</li>
                                                                            <li>Revisión de luces encendidas en el panel.</li>
                                                                        </ul>
                                                                    </div>
                                                                    <br />

                                                                    <lightning:input aura:id="boxPack" type="checkbox" label="He leído y acepto los Términos y Condiciones" onchange="{!c.setVisible}" required="true"/>



                                                                    <lightning:button variant="brand" aura:id="btnAceptar" label="Aceptar" title="Aceptar" disabled="true"  onclick="{! c.closeModalTerminos }" />
                                                                </div>
                                                            </header>

                                                        </div>
                                                    </section>
                                                    <div class="slds-backdrop slds-backdrop_open"></div>
                                               
                                                </div>
                                                <!-- VEHICULOS Y CORREOS -->
                                                <div class="slds-m-around_xx-large" id="vehiculosYcorreos" style="display:none">
                                                                                
                                                    <!-- Modal/Popup Box starts here-->
                                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                                        <div class="slds-modal__container">
                                                            <!-- Modal/Popup Box Header Starts here-->
                                                            <header class="slds-modal__header">
                                                                
                                                                <div class="terms-container">
                                                                    <div style="height: 300px; overflow: scroll;">
                                                                        <p><strong>Hemos detectado estos correos y vehículos asociados a tu cuenta</strong></p>
                                                                        <table id="vehiculosCorreos"  class="" style="font-size:18px">
                                                                            <thead>
                                                                                <tr>
                                                                                    <th style="width: 20%;">Placa</th>                                                                                
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                <aura:iteration items="{!v.listaCoches}" var="item">
                                                                                    <tr>   
                                                                                        <td>{!item.Name}</td>
                                                                                    </tr>
                                                                                </aura:iteration>
                                                                            </tbody>
                                                                        </table>
                                                                    <br/>
                                                                    <p><strong>Si desea modificar esta lista por favor ingrese a la seccion "Gestiona tus vehiculos"</strong></p>
                                                                    </div>
                                                                    <br />

                                                                    <lightning:button variant="brand"  label="Aceptar" title="Aceptar"   onclick="{! c.closeModalVehiculos }" />
                                                                </div>
                                                            </header>

                                                        </div>
                                                    </section>
                                                    <div class="slds-backdrop slds-backdrop_open"></div>

                                                </div>
                                                
                                                <!-- CALENDARIO -->
                                                <div id="container" style="display:none">
                                                    <div id="containerCalendario" class="">
                                                        <div class="calendar-header">
                                                            <a class="prev-button" id="prev">
                                                                <i class="material-icons">keyboard_arrow_left
                                                                </i>
                                                            </a>
                                                            <a class="next-button" id="next">
                                                                <i class="material-icons">keyboard_arrow_right
                                                                </i>
                                                            </a>
                                                            <div class="row header-title">
                                                                <div class="header-text">
                                                                    <h3 id="month-name">February</h3>
                                                                    <h5 id="todayDayName">
                                                                        Today is Friday 7 Feb
                                                                    </h5>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    
                                                    <div class="">
                                                        <div class="calendar-content">
                                                            <div id="calendar-table" class="calendar-cells">
                                                                <div id="table-header">
                                                                    <div class="row">
                                                                        <div class="col">Mon</div>
                                                                        <div class="col">Tue</div>
                                                                        <div class="col">Wed</div>
                                                                        <div class="col">Thu</div>
                                                                        <div class="col">Fri</div>
                                                                        <div class="col">Sat</div>
                                                                        <div class="col">Sun</div>
                                                                    </div>
                                                                </div>
                                                                <div id="table-body" class=""></div>
                                                            </div>
                                                        </div>
                                                        <div class="popup" id="testToggle" style="">
                                                            <span class="popuptext" id="myPopup">
                                                                <lightning:button variant="base" label="Continuar" title="Continuar" onclick="{! c.myTest }" />
                                                            </span>
                                                        </div>                                                        
                                                        <br/>
                                                        <br/>
                                                        <br/>
                                                        <div class="fixed" id="sidebarMovil" style="display:none;background-color: white;text-align:center">
                                                            <div class="" style="padding-bottom:40px;">
                                                                <lightning:button variant="brand" label="Reservacion tentativa conforme a la disponibilidad de la movil" title="Reservacion tentativa conforme a la disponibilidad de la movil" onclick="{! c.nuevaCitaMovil }" />                                                                                                           
                                                            </div>
                                                        </div>
                                                        <div class="fixed" id="sidebar" style="display:none">
                                                            <div class="sidebar-title">
                                                                <h4 id="eventDayName" class="month-name">
                                                                    Date
                                                                </h4>

                                                                <h5 id="sidebar-texttitle" class="available-Citations">
                                                                    Citas Disponibles: 0

                                                                </h5>
                                                            </div>
                                                            <div class="container">
                                                                <div class="sidebar-events row" id="sidebarEvents">

                                                                </div>
                                                                <div class="empty-message">
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>

                                                

                                                <div class="calendar-footer" style="display:none">
                                                    <div class="emptyForm" id="emptyForm">
                                                        <h4 id="emptyFormTitle">No events now</h4>
                                                        <a class="addEvent" id="changeFormButton">Add new
                                                        </a>
                                                    </div>
                                                    <div class="addForm" id="addForm">
                                                        <h4>Add new event</h4>
                                                        <div class="row">
                                                            <div class="input-field col s6">
                                                                <input id="eventTitleInput" type="text" class="validate" />
                                                                <label for="eventTitleInput">Title </label>
                                                            </div>
                                                            <div class="input-field col s6">
                                                                <input id="eventDescInput" type="text" class="validate" />
                                                                <label for="eventDescInput">Description
                                                                </label>
                                                            </div>
                                                        </div>
                                                        <div class="addEventButtons">
                                                            <a class="waves-effect waves-light btn blue lighten-2" id="addEventButton">Add
                                                            </a>
                                                            <a class="waves-effect waves-light btn grey lighten-2" id="cancelAdd">Cancel
                                                            </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <!--Aquí va lo de JD-->
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- / Content -->
                    </div>
                    <!-- Footer -->
                    <footer class="content-footer footer bg-footer-theme">
                        <div class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">
                            
                            <div class="mb-2 mb-md-0">
                                © 2024. Comunidad RedMotors. By PortalNet.
                                <a class="mb-2 mb-md-0" onclick="{! c.mostrarTerminos }">Terminos y condiciones</a>
                            </div>
                            <div></div>
                        </div>
                    </footer>
                    <!-- / Footer -->
                    <div class="content-backdrop fade"></div>
                </div>
                <!-- Content wrapper -->
            </div>
            <!-- / Layout page -->
        </div>
        <!-- Overlay -->
        <div id="overlayMenu" onclick="{! c.hideMenu }" class="layout-overlay layout-menu-toggle"></div>
        <!-- Core JS -->
        <!-- build:js assets/vendor/js/core.js -->
        <!-- endbuild -->
        <!-- Vendors JS -->
        <!-- Main JS -->
        </aura:if>
        <button class="floating-button desktop" style="position: fixed;bottom: -1px;right: 20px;z-index: 999; border-radius: 50%;background-color:transparent;border-color:transparent;  padding: 10px;" onclick="{!c.openModalCase}">        
            <div class="main-div" style="width: 300px;height: 50px;">
                <div class="blue-circle" style="display: flex;height: 50px;width: 50px;background-color: white;border-radius: 50%;position: absolute;left: 5px;z-index: 999;top: 15px">
                    <div class="text-div" style="top: 9%;left: 10%;background-color:white;height: 40px;width: 40px;position: absolute;border-radius:50px;height: 40px;width: 40px;background-position:center;" ><img src="{!$Resource.chatImage}" alt="Italian Trulli"/></div>
                </div>
                <div class="black-side" style="display: flex;justify-content: center;align-items: center;width: 100%;height: 40%;top: 0;position: absolute;background-color: black;color: white;border-top-left-radius: 5px;border-top-right-radius: 5px;font-weight: bold;">
                    <p class="desktop">BMW</p>
                    <p class="mobile">Consultas</p>
                </div>
                <div class="gray-side" style="display: flex;justify-content: center;align-items: center;width: 100%;height: 60%;bottom: 0;position: absolute;background-color: white;border-style: outset;border-bottom-left-radius: 5px;border-bottom-right-radius: 5px;font-weight: bold;">
                    <p class="desktop">¿Tienes dudas?</p>
                </div>
            </div>
          </button>

        <button class="floating-button mobile" style="position: fixed;z-index: 999;bottom: 25px;right: 20px;border-radius: 15px;background-color:transparent;border-color: transparent; width:85px" onclick="{!c.openModalCase}">        
            <div>
                <div class="cons-container">
                    <p>Consultas</p>
                </div>
                <div class="bottom-container">
                    <img src="{!$Resource.chatImage}" alt="Italian Trulli"/>
                </div>
            </div> 
        </button>
    </body>
    
    </html>
</aura:component>