<aura:component implements="lightning:isUrlAddressable,force:hasRecordId,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes" access="global" controller="CommunityCalendarController">
    <aura:attribute name="controllerFirstRun" type="boolean" default="false" />
    <aura:handler name="init" value="this" action="{!c.doInit}" />
    <aura:attribute name="isComboboxRendered" type="Boolean" default="false" />
    <aura:attribute name="hasRun" type="Boolean" default="false" />

    <aura:attribute name="isDoneRendering" type="Boolean" default="false"/>
    <!-- LISTAS PARA CONTROLAR LAS RESERVAS -->
    <aura:attribute name="horasReservas" type="List" />
    <aura:attribute name="servicioUrl" type="String" />
    <aura:attribute name="selectedValue" type="String" default="" />
    <aura:attribute name="marcaUrl" type="String" default="" />
    <aura:attribute name="tipoCita" type="Boolean" default="false" />
    <aura:attribute name="espacioNoOcupado" type="Boolean" default="false" />
    <aura:attribute name="formuLLeno" type="Boolean" default="false" />
    <aura:attribute name="inputCount" type="List"  />
    <aura:attribute name="asesoresXcomunidad" type="List"  />
    <aura:attribute name="mecanicosXespacio" type="Integer"/>
    <aura:attribute name="isModalOpenSoporte" type="Boolean" default="false" />
    <aura:attribute name="isModalCitaMovil" type="boolean" default="false" />
    <!-- FORMULARIO PREGUNTAS -->
    <aura:attribute name="url" type="String"/>
    <aura:attribute name="correUnaVez" type="Boolean"  default="false"/>
    <aura:attribute name="Servicio" type="String"/>
    <aura:attribute name="pregunta1" type="String" />
    <aura:attribute name="pregunta2" type="String" />
    <aura:attribute name="pregunta3" type="String" />
    <aura:attribute name="pregunta4" type="String" />
    <aura:attribute name="pregunta5" type="String" />
    <aura:attribute name="pregunta6" type="String" />
    <aura:attribute name="pregunta7" type="String" />
    <aura:attribute name="pregunta8" type="String" />
    <aura:attribute name="pregunta9" type="String" />
    <aura:attribute name="pregunta10" type="String" />
    <aura:attribute name="pregunta11" type="String" />
    <aura:attribute name="pregunta12" type="String" />
    <aura:attribute name="pregunta13" type="String" />
    <aura:attribute name="pregunta14" type="String" />
    <aura:attribute name="pregunta15" type="String" />
    <aura:attribute name="pregunta16" type="String" />
    <aura:attribute name="pregunta17" type="String" />
    <aura:attribute name="pregunta18" type="String" />
    <aura:attribute name="pregunta19" type="String" />
    <aura:attribute name="pregunta20" type="String" />
    <aura:attribute name="citaMovil" type="Boolean" default="false" />
    <aura:attribute name="mecanicosSucursal" type="Decimal" />
    <aura:attribute name="minutosSucursal" type="Decimal" />
    <aura:attribute name="startDateHour" type="String" />

    <!-- Fecha en español -->
    <aura:attribute name="startDateHourEsp" type="String" />
    <aura:attribute name="descripcionCase" type="String" />
    <aura:attribute name="isModalNewCase" type="Boolean" default="false"/>
    
    <aura:attribute name="setIntervalId" type="Integer"/>
    <aura:attribute name="tiempoTimer" type="Integer"/>

    <!-- Contact Information -->
    <aura:attribute name="userInfo" type="user" />
    <aura:attribute name="userName" type="String" />
    <aura:attribute name="userPhone" type="String" />
    <aura:attribute name="userEmail" type="String" />

    <!-- Next User Citations - Information -->
    
    <aura:attribute name="listaCoches" type="List" />
    <aura:attribute name="asesorXcalendario" type="List" />
    <aura:attribute name="userEvents" type="List" />
    <aura:attribute name="userEvent" type="Event" />
    <aura:attribute name="eventLocation" type="String" />
    <aura:attribute name="eventCarId" type="String" />
    <aura:attribute name="eventStartDate" type="String" />
    <aura:attribute name="eventId" type="String" />
    <aura:attribute name="contactId" type="String" />
    
    <aura:attribute name="calendarList" type="List" />
    <aura:attribute name="selectedPlaca" type="String" />
    <aura:attribute name="eventosActuales" type="List" />
    <aura:attribute name="selectedSucursal" type="String" />

    <aura:attribute name="userAssets" type="List" />
    <aura:attribute name="hasNoAssets" type="boolean" default="true" />
    <aura:attribute name="additionalComments" type="string" default="" />
    <aura:attribute name="estimatedKM" type="string" default="" />
    <aura:attribute name="isModalOpenExistingCitation" type="boolean" default="false" />
    <aura:attribute name="isModalOpenConfirmation" type="boolean" default="false" />
    <aura:attribute name="isModalChangeMarca" type="boolean" default="false" />
    <aura:attribute name="isModalOtro" type="boolean" default="false" />
    
    <!--NUEVAS VARIABLES PARA MODALES-->
    <aura:attribute name="isModalMinutes" type="boolean" default="false" />
    <aura:attribute name="isModalOffMinutes" type="boolean" default="false" />

    <aura:attribute name="isModalLibreDeCitas" type="boolean" default="false" />

    <aura:attribute name="isModalOpenFinalConfirmation" type="boolean" default="false" />
    <aura:attribute name="marcaSelected" type="String" default="BMW" />
    <aura:attribute name="marcasPagina" type="List" default="[{'label': 'BMW', 'value': 'BMW'}, {'label': 'MINI', 'value': 'MINI'}, {'label': 'Motorrad', 'value': 'Motorrad'}]" />

    <!-- Información Próximo Evento Agendado Vehículo Seleccionado -->
    <aura:attribute name="vehiculeIdEvent" type="Event" />

    <aura:attribute name="response" type="String" />

    <!-- User Selections -->
    <aura:attribute name="serviceSelected" type="String" />
    <aura:attribute name="vehicleSelected" type="String" />
    <aura:attribute name="ownVehicleSelected" default="" type="String" />
    <aura:attribute name="vehicleId" type="String" />
    <aura:attribute name="myResult" type="String" />
    <aura:attribute name="subServiceWasSelected" type="boolean" default="false"/>

    <aura:attribute name="services" type="Object" default='[ {"Mecánica Rápida":[{ "label":"Escazú","id":"0054U000009hipBQAQ" }, { "label":"Pavas","id":"0054U000009hiw2QAA" }, { "label":"Pinares","id":"0054U000009hiwHQAQ" }, { "label":"Uruca","id":"0054U000009hiwMQAQ" } ], "Mecánica general":[ { "label":"Pavas","id":"0054U000009hiwCQAQ" }, { "label":"Uruca","id":"0054U000009hiwRQAQ" } ], "Otobai":[ { "label":"Pavas","id":"0054U00000Bes4GQAR" } ], "Enderezado y Pintura":[ { "label":"Uruca","id":"0054U000009hiwWQAQ"}]}]' />
    <aura:attribute name="serviceCenterSelected" type="String" />
    <aura:attribute name="serviceCenterSelectedName" type="String" />
    <aura:attribute name="selectedDate" type="Date" />
    <aura:attribute name="selectedHour" type="Date" />
    <aura:attribute name="serviceCenters" type="List" />
    <aura:attribute name="optionsService" type="List" default="[]" />
    <aura:attribute name="optionsVehicule" type="List" default="[{'label': 'Vehículo Propio', 'value': 'Vehículo Propio'}]" />
    <aura:attribute name="tabs" type="Object[]" />
    <aura:attribute name="selTabId" type="String" />

    <aura:attribute name="optionsErrors" type="List" default="[{'label': 'Otro', 'value': 'Otro'}]"/>

    <aura:attribute name="isLoading" type="Boolean" default="true"/>
    <aura:attribute name="isLoadingNo" type="Boolean" default="true"/>

    <aura:method name="logParam" description="Sample method with parameter">
        <aura:attribute name="message" type="String" default="default message" />
    </aura:method>

    <aura:handler name="render" value="{!this}" action="{!c.onRender}"/>

    <html lang="en" class="light-style layout-menu-fixed">
    <!--Community Calendar Components -->
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=yes" />
    <title>Citas-BMW</title>
        <link rel="icon" type="image/x-icon" href="/images/favicon.ico"></link>

    <!-- CSS -->
    <ltng:require styles="{!$Resource.CustomerCommunitiesAdditionalStyles}" /> <!-- Nuestros CSSs -->
    <ltng:require styles="{!$Resource.CommunityCalendarStyle}" /> <!-- Nuestros CSSs -->
    <ltng:require styles="{!$Resource.CommunityCalendarStyleComplement}" /> <!-- Nuestros CSSs -->


    <ltng:require styles="{!$Resource.CustomerCommunity_corecss}" /> <!-- Template CSSs -->
    <ltng:require styles="{!$Resource.CustomerCommunity_themeDefault}" /> <!-- Template CSSs -->
    <ltng:require styles="{!$Resource.CustomerCommunityFiles + 'CustomerCommunity/assets/vendor/fonts/boxicons.css'}" /> <!-- Template CSSs -->

    <ltng:require scripts="{!join(',', $Resource.CommunityCalendarFiles + '/jquery.min.js',
                       $Resource.CommunityCalendarFiles + '/materialize.min.js', 
                       $Resource.CommunityCalendarFiles + '/popper.min.js',
                       $Resource.CommunityCalendarFiles + '/bootstrap.min.js' )}" afterScriptsLoaded="{!c.myFunction}" />

    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
        <title> </title>
        <meta name="description" content="" />
        <!-- Fonts -->
    </head>

    <body>
        <!-- Layout wrapper -->
        
        <aura:if isTrue="{!v.isLoading}">
            <!-- Add your spinner markup or use Salesforce's spinner component here -->
            <!-- For example, you can use SLDS (Salesforce Lightning Design System) spinner -->
            <div class="spinner-container" style="background-color: rgba(0, 0, 0, 0.9);top: 0;left: 0;position:fixed;width: 100%;height: 100%; align-items: center;justify-content: center;z-index: 9999;">
                <div class="slds-spinner slds-spinner_medium">
                    <div class="slds-spinner__dot-a"></div>
                    <div class="slds-spinner__dot-b"></div>
                </div>
            </div>
        </aura:if>
        <aura:if isTrue="{!v.isLoadingNo}">
        <div class="layout-wrapper layout-content-navbar">
            <div class="layout-container">
                <!-- Menu -->
                <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
                    <div class="app-brand demo">
                        <a class="app-brand-link">
                            <a class="app-brand-link">
                                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                                    <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                                    <img src="{!$Resource.communityMINI}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                                    <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                            </a>
                        </a>
                        <a class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none"> <i class="bx bx-chevron-left bx-sm align-middle"> </i> </a>
                    </div>
                    <div class="menu-inner-shadow"></div>
                    <ul class="menu-inner py-1">
                        <!-- Dashboard -->
                        <!-- <li class="menu-item">
                            <a class="menu-link">
                                <i class="menu-icon tf-icons bx bx-home-circle"> </i>
                                <div data-i18n="Analytics">Próximamente</div>
                            </a>
                        </li> -->
                        <li class="menu-header small text-uppercase">
                            <span class="menu-header-text">Gestión de Citas</span>
                        </li>


                        <aura:if isTrue="{!v.userInfo.Id != 'II0058N000001zbY4QAI'}">
                            <li class="menu-item">
                                <a class="menu-link menu-toggle">
                                    <i class="menu-icon tf-icons bx bx-dock-top"> </i>
                                    <div class="under active" data-i18n="Account Settings">Nueva Cita</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                        </aura:if>

                        <aura:if isTrue="{!v.userInfo.Id == 'I0058N000001zbY4QAI'}">
                            <li class="menu-item">
                                <a class="menu-link menu-toggle" href="{!'/s/disponibilidades?servicio=' +  v.marcaSelected}">
                                    <i class="menu-icon tf-icons bx bx-dock-top"> </i>
                                    <div class="under active" data-i18n="Account Settings">Nueva Cita Asesor</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                        </aura:if>


                        <aura:if isTrue="{!v.userInfo.Id != 'I0058N000001zbY4QAI'}"> 
                            <li class="menu-item">
                                <a class="menu-link menu-toggle" href="{!'/s/communitycancelappointments?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                                    <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                                    <div class="under" data-i18n="Authentications">Modificar Cita</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                            <li class="menu-item">
                                <a class="menu-link menu-toggle" href="{!'/s/communityappointmentshistory?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                                    <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                                    <div class="under" data-i18n="Authentications">Historial de Citas</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                            <li class="menu-item">
                                <a class="menu-link menu-toggle"  onclick="{! c.openSoporte }">
                                    <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                                    <div class="under" data-i18n="Authentications">Asistencia en Linea</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                            <li class="menu-item">
                                <a class="menu-link menu-toggle" href="{!'/s/gestionavehiculos?id=' + v.contactId}">
                                    <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                                    <div class="under" data-i18n="Authentications">Gestiona tus vehiculos</div>
                                </a>
                                <ul class="menu-sub"></ul>
                            </li>
                            <!-- Components -->
                            <li class="menu-header small text-uppercase">
                                <span class="menu-header-text">Mi Perfil </span>
                            </li>
                            <!-- Cards -->
                            <li class="menu-item">
                                <a class="menu-link">
                                    <i class="menu-icon tf-icons bx bx-collection"> </i>
                                    <div class="under" data-i18n="Basic">Próximamente</div>
                                </a>
                            </li>
                            <li class="menu-item">
                                <a class="menu-link"  href="/secur/logout.jsp">
                                    <i class="menu-icon tf-icons bx bx-collection"> </i>
                                    <div class="under" data-i18n="Basic">LogOut</div>
                                </a>
                            </li>
                        </aura:if>
                    </ul>
                </aside>
                <!-- / Menu -->
                <!-- Layout container -->
                <div class="layout-page">

                    <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                        <img src="{!$Resource.BMWCar}" alt="BMWLogo" class="banner-image"/>
                    </aura:if>
                    <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                        <img src="{!$Resource.MINICar}" alt="BMWLogo" class="banner-image"/>
                    </aura:if>
                    <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                        <img src="{!$Resource.MotoCar}" alt="BMWLogo" class="banner-image"/>
                    </aura:if>


                    <!-- Navbar -->
                    <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme" id="layout-navbar">
                        <div class="app-brand demo logo-mobile">
                            <a class="app-brand-link">
                                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                                    <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                                    <img src="{!$Resource.communityMINI}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                                    <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                                </aura:if>
                            </a>
                        </div>
                        <div class=" layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
                            <a class="nav-item nav-link px-0 me-xl-4">
                                <i class="bx bx-menu bx-sm"> </i>
                            </a>
                        </div>
                        <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
                            <!-- /Search -->
                            <ul class="navbar-nav flex-row align-items-center ms-auto">
                                <!-- Place this tag where you want the button to render. -->
                                <li class="nav-item lh-1 me-3 welcome-text">
                                    <span>
                                        <ui:outputText value="{!v.userName}" />
                                    </span>
                                </li>
                            </ul>
                            <!-- Search -->
                            <div class=" hamburguesa navbar-nav align-items-center">
                                <div id="barMenu" onclick="{! c.showMenu }" style=" top:0;left:0;">
                                    <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                                    <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                                    <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                                </div>
                                <div class="nav-item d-flex align-items-center"></div>
                            </div>
                        </div>
                    </nav>
                    <!-- / Navbar -->
                    <!-- Content wrapper -->
                    <div class="content-wrapper">
                        <!-- Content -->
                        <div class="container-xxl flex-grow-1 container-p-y">
                            <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
                                <!-- Search -->
                                <div class=" navbar-nav align-items-center">
                                    <h4 class="fw-bold py-3 mb-4 title-principal">Citas de taller.</h4>                                        
                                </div>
                                <!-- /Search -->
                                <div class="navbar-nav  ms-auto ">
                                    <button class="btn cambiarMarca  btn-primary btn-block" onclick="{! c.mostrarCambiarMarca }"> Cambiar marca </button>
                                </div>
                            </div>

                            <div class="slds-m-around_xx-large">
                                <aura:if isTrue="{!v.isModalChangeMarca}">

                                    <!-- Modal/Popup Box starts here-->
                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container">
                                            <!-- Modal/Popup Box Header Starts here-->
                                            <header class="slds-modal__header">
                                                <div id="creandocita1_">
                                                    <span class="citation-message"> Estas en  {!v.marcaSelected} </span> <br />
                                                    <div class="cambio-marca">
                                                        <b>¿Quieres cambiar?:  </b>
                                                        <lightning:combobox class="form-control" id="checkMarcas" name="general" placeholder="Marcas" options="{! v.marcasPagina }" onchange="{! c.handleOnChangeSelectedMarca }" />
                                                        <br/>
                                                    </div>                                                                                    
                                                </div>

                                                <div id="creandocita2_" style="padding-top:2px">
                                                    <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.cerrarCambiarMarca }" />

                                                    <lightning:button variant="brand" label="Presiona para confirmar" title="Presiona para confirmar" onclick="{! c.handleAceptarMarca }" />
                                                </div>
                                                
                                            </header>

                                        </div>
                                    </section>
                                    <div class="slds-backdrop slds-backdrop_open"></div>
                                </aura:if>
                            </div>


                            
                                <aura:if isTrue="{!v.isModalMinutes}">
                                    <div class="slds-m-around_xx-large">
                                    <!-- Modal/Popup Box starts here-->
                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container">
                                            <!-- Modal/Popup Box Header Starts here-->
                                            <header class="slds-modal__header">
                                                <div id="creandocita1_" style="margin: 0 auto">
                                                    <span class="citation-message"> Tiene 3 minutos para elegir. </span> <br />                                                                                                        
                                                </div>
                                                <br/>
                                                <div id="creandocita2_" style="padding-top:2px">          
                                                    <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.cerrarAceptaMinutes }" />                                         
                                                    <lightning:button variant="brand" label="Presiona para confirmar" title="Presiona para confirmar" onclick="{! c.handleAceptaMinutes }" />
                                                </div>
                                                
                                            </header>

                                        </div>
                                    </section>
                                    <div class="slds-backdrop slds-backdrop_open"></div>
                                </div>
                                </aura:if>
                            

                            <div class="slds-m-around_xx-large">
                                <aura:if isTrue="{!v.isModalOtro}">

                                    <!-- Modal/Popup Box starts here-->
                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container">
                                            <!-- Modal/Popup Box Header Starts here-->
                                            <header class="slds-modal__header">
                                                <div id="creandocita1_">
                                                    <span class="citation-message"> Otro cliente esta viendo este horario, por favor seleccione otro. </span> <br />                                                                                                        
                                                </div>
                                                <br/>
                                                <br/>
                                                <div id="creandocita2_" style="padding-top:2px">          
                                                    <lightning:button variant="neutral" label="Volver" title="Volver" onclick="{! c.cerrarModalOtro }" />                                         
                                                </div>
                                                
                                            </header>

                                        </div>
                                    </section>
                                    <div class="slds-backdrop slds-backdrop_open"></div>
                                </aura:if>
                            </div>

                            <div class="slds-m-around_xx-large">
                                <aura:if isTrue="{!v.isModalOffMinutes}">

                                    <!-- Modal/Popup Box starts here-->
                                    <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                                        <div class="slds-modal__container">
                                            <!-- Modal/Popup Box Header Starts here-->
                                            <header class="slds-modal__header">
                                                <div id="creandocita1_">
                                                    <span class="citation-message"> Tiempo agotado. </span> <br />                                                                                                                                      
                                                </div>
                                                <br/>
                                                <br/>
                                                <div id="creandocita2_" style="padding-top:2px">                                                    
                                                    <lightning:button variant="brand" label="Presiona para confirmar" title="Presiona para confirmar" onclick="{! c.handleAceptaOffMinutes }" />
                                                </div>
                                                
                                            </header>

                                        </div>
                                    </section>
                                    <div class="slds-backdrop slds-backdrop_open"></div>
                                </aura:if>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <div class="card-2 mb-4">
                                        <div class="card-body">
                                            <!--JD-->
                                            <div id="calendarComponent" class="calendar-wrapper z-depth-2">
                                                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                                                    <div class="desktop" style="margin: auto; width: 100%; padding: 0px; box-shadow: 1px 1px 6px grey;"><img src="{!$Resource.encabezadoBMW}" alt="BMWHeader"  /></div>
                                                </aura:if>
                                                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                                                    <div class="desktop" style="margin: auto; width: 100%; padding: 0px; box-shadow: 1px 1px 6px grey;"><img src="{!$Resource.encabezadoMini}" alt="BMWHeader"  /></div>
                                                </aura:if>
                                                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
