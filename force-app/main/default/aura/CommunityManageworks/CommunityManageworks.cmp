<aura:component
  implements="lightning:isUrlAddressable,force:hasRecordId,flexipage:availableForAllPageTypes,forceCommunity:availableForAllPageTypes"
  access="global" controller="communityManageWorks_ctrl">

  <aura:handler name="init" value="this" action="{!c.doInit}" />
  <aura:attribute name="controllerFirstRun" type="boolean" default="false" />
  <aura:attribute name="activeSections" type="List" default="['A']" />
  <aura:attribute name="activeSectionsMessage" type="String" default="" />
  <aura:attribute name="isOpen" type="Boolean" default="true" />
  <aura:attribute name="isOpen2" type="Boolean" default="true" />
  <aura:attribute name="isOpen3" type="Boolean" default="true" />
  <aura:attribute name="isOpen4" type="Boolean" default="true" />
  <aura:attribute name="isModalInsc" type="Boolean" default="false" />
  <aura:attribute name="isActive" type="Boolean" default="false" />
  <aura:attribute name="loaded" type="Boolean" default="false" />
  <aura:attribute name="caseId" type="String" default="" />
  <aura:attribute name="approvedNecesario" type="List" />
  <aura:attribute name="approvedRecomendado" type="List" />
  <aura:attribute name="approvedSugerido" type="List" />

  <aura:attribute name="marcaUrl" type="String" default="" />
  <aura:attribute name="userName" type="String" default="" />
  <aura:attribute name="descripcionCase" type="String" default="" />
  <aura:attribute name="isModalChangeMarca" type="boolean" default="false" />
  <aura:attribute name="marcaSelected" type="String" default="BMW" />
  <aura:attribute name="marcasPagina" type="List"
    default="[{'label': 'BMW', 'value': 'BMW'}, {'label': 'MINI', 'value': 'MINI'}, {'label': 'Motorrad', 'value': 'Motorrad'}]" />

  <aura:attribute name="isModalNewCase" type="Boolean" default="false" />

  <!-- Todos los ids a actualizar -->
  <aura:attribute name="dataToUpdate" type="Object[]" />
  <!-- Cantidades Individuales -->
  <aura:attribute name="currencyIso" type="String" default="" />
  <aura:attribute name="cantidadRecomendado" type="String" default="" />
  <aura:attribute name="cantidadSugerido" type="String" default="" />
  <aura:attribute name="cantidadNecesario" type="String" default="" />
  <aura:attribute name="numOrden" type="String" default="" />
  <!-- Cantidades todo aprobado-->
  <aura:attribute name="cantidadAprobado" type="String" default="0" />
  <aura:attribute name="cantidadPresupuesto" type="String" default="0" />
  <aura:attribute name="cantidadTotal" type="String" default="0" />
  <aura:attribute name="cantidadVerdes" type="String" default="0" />
  <!-- Informacion del vehiculo -->
  <aura:attribute name="placa" type="String" default="DBZ0098" />
  <aura:attribute name="marca" type="String" default="BMW" />
  <aura:attribute name="modelo" type="String" default="" />
  <aura:attribute name="anio" type="String" default="" />
  <aura:attribute name="vin" type="String" default="" />
  <aura:attribute name="kilometraje" type="String" default="" />
  <aura:attribute name="combustible" type="String" default="" />
  <!-- Informacion del propietario -->
  <aura:attribute name="propietario" type="String" default="" />
  <aura:attribute name="contacto" type="String" default="" />
  <aura:attribute name="cedula" type="String" default="" />
  <aura:attribute name="telefono" type="String" default="" />
  <aura:attribute name="correo" type="String" default="" />
  <aura:attribute name="ubicacion" type="String" default="" />
  <aura:attribute name="recepcionista" type="String" default="" />
  <aura:attribute name="fechaEntrada" type="String" default="" />
  <aura:attribute name="direccion" type="String" default="" />
  <aura:attribute name="todosNombres" type="Object[]" />
  <aura:attribute name="todosNombresInverso" type="Object[]" />
  <aura:attribute name="tipoVehiculo" type="String" default="" />
  <aura:attribute name="disabledButon" type="Boolean" default="false" />


  <aura:attribute name="totalNecesario" type="String" default="0" />
  <aura:attribute name="totalRecomendado" type="String" default="0" />
  <aura:attribute name="totalSugerido" type="String" default="0" />


  <aura:attribute name="totalNecesarioFinal" type="String" default="0" />
  <aura:attribute name="totalRecomendadoFinal" type="String" default="0" />
  <aura:attribute name="totalSugeridoFinal" type="String" default="0" />

  <aura:attribute name="tipoTrabajoNombre" type="String" default="0" />

  <aura:attribute name="categoriaServicio" type="String" default="" />

  <aura:attribute name="isChecked" type="Boolean" default="false" />

  <aura:attribute name="isConfirmButtonDisabled" type="Boolean" default="true" />

  <aura:attribute name="isModalOpenSoporte" type="boolean" default="false" />

  <aura:attribute name="estadoActual" type="String" default="" />

  <!-- Variables del timeline -->
  <aura:attribute name="steps" type="List" default="[
  'Sin etapa', 'Recibido', 'Ingreso Torre de Control', 'Programación', 'Asignado',
  'En Proceso', 'Pruebas', 'Trabajo externo', 'Pintura', 'Creando presupuesto',
  'Presupuesto autorizado', 'Presupuesto listo', 'Control de calidad', 'Lavado',
  'Pedido especial (Varado)', 'Pedido especial (Rodando)', 'Vehículo Listo', 'Entregado'
  ]" />

  <aura:attribute name="stages" type="List" />
  <aura:attribute name="currentStage" type="String" />

  <aura:attribute name="activeIndex" type="Integer" default="0" />
  <aura:attribute name="stepWrappers" type="List" />

  <aura:attribute name="testImgUrl" type="String" default="/resource/1728316874000/testBMWimg" />

  <html lang="en" class="light-style layout-menu-fixed">
  <!--Community Calendar Components -->
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=yes" />

  <!-- CSS -->
  <ltng:require styles="{!$Resource.CommunityCalendarStyle}" /> <!-- Nuestros CSSs -->
  <ltng:require styles="{!$Resource.CommunityCalendarStyleComplement}" /> <!-- Nuestros CSSs -->
  <ltng:require styles="{!$Resource.CustomerCommunitiesAdditionalStyles}" /> <!-- Nuestros CSSs -->

  <ltng:require styles="{!$Resource.CustomerCommunity_corecss}" /> <!-- Template CSSs -->
  <ltng:require styles="{!$Resource.CustomerCommunity_themeDefault}" /> <!-- Template CSSs -->
  <!-- <ltng:require styles="{!$Resource.CustomerCommunityFiles + 'CustomerCommunity/assets/vendor/fonts/boxicons.css'}" /> -->
  <!-- Template CSSs -->

  <head>
    <meta charset="utf-8" />
    <meta name="viewport"
      content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <title>Gestionar trabajos a realizar</title>
    <meta name="description" content="" />
    <!-- Fonts -->
  </head>

  <body>
    <aura:if isTrue="{!v.isLoading}">
      <div class="spinner-container"
        style="background-color: rgba(0, 0, 0, 0.9);top: 0;left: 0;position:fixed;width: 100%;height: 100%; align-items: center;justify-content: center;z-index: 9999;">
        <div class="slds-spinner slds-spinner_medium">
          <div class="slds-spinner__dot-a"></div>
          <div class="slds-spinner__dot-b"></div>
        </div>
      </div>
    </aura:if>
    <div class="layout-wrapper layout-content-navbar">
      <div class="layout-container">
        <aside id="layout-menu" class="layout-menu menu-vertical menu bg-menu-theme">
          <div class="app-brand demo">
            <a class="app-brand-link" href="{!'/s/?servicio=' + v.marcaSelected}">
              <a class="app-brand-link" href="{!'/s/?servicio=' + v.marcaSelected}">
                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                  <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                  <img src="{!$Resource.communityMINI}" alt="MINI Logo" style="max-width: 175px;" />
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                  <img src="{!$Resource.BMWServiceLogo}" alt="Motorrad Logo" style="max-width: 175px;" />
                </aura:if>
              </a>
            </a>
            <a class="layout-menu-toggle menu-link text-large ms-auto d-block d-xl-none"> <i
                class="bx bx-chevron-left bx-sm align-middle"> </i> </a>
          </div>
          <div class="menu-inner-shadow"></div>
          <ul class="menu-inner py-1">
            <li class="menu-header small text-uppercase">
              <span class="menu-header-text">Citas de Servicio</span>
            </li>
            <li class="menu-item">
              <a class="menu-link menu-toggle " href="{!'/s/communitymenu?servicio=' + v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                <div class="under" data-i18n="Authentications">Nueva Cita</div>
              </a>
              <ul class="menu-sub"></ul>
            </li>
            <li class="menu-item">
              <a class="menu-link menu-toggle"
                href="{!'/s/communitycancelappointments?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                <div class="under" data-i18n="Authentications">Modificar Cita</div>
              </a>
              <ul class="menu-sub"></ul>
            </li>
            <li class="menu-item">
              <a class="menu-link menu-toggle"
                href="{!'/s/communityappointmentshistory?id=' + v.contactId + '&amp;marca=' +  v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-lock-open-alt"> </i>
                <div class="under" data-i18n="Authentications">Historial de Citas</div>
              </a>
              <ul class="menu-sub"></ul>
            </li>

            <!-- Components -->

            <li class="menu-header small text-uppercase">
              <span class="menu-header-text">Presupuestos</span>
            </li>
            <li class="menu-item">
              <a class="menu-link" href="{!'/s/communitymanageworksmenu?servicio=' + v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-collection"> </i>
                <div class="under active" data-i18n="Basic">Aprobar presupuesto</div>
              </a>
            </li>
            <li class="menu-item">
              <a class="menu-link" href="{!'/s/communityinspectionhistory?servicio=' + v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-collection"> </i>
                <div class="under" data-i18n="Basic">Historial de inspecciones</div>
              </a>
            </li>
            <li class="menu-header small text-uppercase">
              <span class="menu-header-text">Perfil </span>
            </li>
            <!-- Cards -->
            <li class="menu-item">
              <a class="menu-link" href="{!'/s/communityprofile?servicio=' + v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-collection"> </i>
                <div class="under " data-i18n="Basic">Perfil</div>
              </a>
            </li>
            <li class="menu-item">
              <a class="menu-link" href="{!'/s/communitycarsmanagement?servicio=' + v.marcaSelected}">
                <i class="menu-icon tf-icons bx bx-collection"> </i>
                <div class="under" data-i18n="Basic">Información de mi auto</div>
              </a>
            </li>
            <li class="menu-header small text-uppercase" >
              <a class="menu-link" onclick="{! c.openSoporte }">
                <div style="font-size: 13px; color:#697A8D" class="under" data-i18n="Authentications">Asistencia en
                  Linea</div>
              </a>
            </li>
            <li class="menu-header small text-uppercase" style="margin-top: 0;">
              <a class="menu-link" href="/secur/logout.jsp">
                <div style="font-size: 13px; color:#697A8D" class="under" data-i18n="Basic">LogOut</div>
              </a>
            </li>
          </ul>
        </aside>
        <!-- / Menu -->
        <!-- Layout container -->
        <div class="layout-page">
          <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
            <img src="{!$Resource.BMWCar}" alt="BMWLogo" class="banner-image" />
          </aura:if>
          <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
            <img src="{!$Resource.MINICar}" alt="BMWLogo" class="banner-image" />
          </aura:if>
          <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
            <img src="{!$Resource.MotoCar}" alt="BMWLogo" class="banner-image" />
          </aura:if>

          <nav
            class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme"
            id="layout-navbar">
            <div class="app-brand demo logo-mobile">
              <a class="app-brand-link">
                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                  <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                  <img src="{!$Resource.communityMINI}" alt="BMWLogo" style="max-width: 175px;" />
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                  <img src="{!$Resource.BMWServiceLogo}" alt="BMWLogo" style="max-width: 175px;" />
                </aura:if>
              </a>
            </div>
            <div class=" layout-menu-toggle navbar-nav align-items-xl-center me-3 me-xl-0 d-xl-none">
              <a class="nav-item nav-link px-0 me-xl-4">
                <i class="bx bx-menu bx-sm"> </i>
              </a>
            </div>
            <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
              <!-- /Search -->
              <ul class="navbar-nav flex-row align-items-center ms-auto">
                <!-- Place this tag where you want the button to render. -->
                <li class="nav-item lh-1 me-3 welcome-text">
                  <span>
                    <ui:outputText value="{!v.userName}" />
                  </span>
                </li>
              </ul>
              <!-- Search -->
              <div class=" hamburguesa navbar-nav align-items-center">
                <div id="barMenu" onclick="{! c.showMenu }" style=" top:0;left:0;">
                  <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                  <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                  <div style="width: 30px;height: 3px;background-color: black;margin: 6px 0;"></div>
                </div>
                <div class="nav-item d-flex align-items-center"></div>
              </div>
            </div>
          </nav>

          <!-- Content wrapper -->
          <div class="content-wrapper">
            <!-- Content -->
            <div class="container-xxl flex-grow-1 container-p-y">
              <div id="barMenu" class="hamburguesa" onclick="{! c.showMenu }" style=" top:0;left:0;">
                <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
                <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
                <div style="width: 35px;height: 5px;background-color: black;margin: 6px 0;"></div>
              </div>
              <div class="navbar-nav-right d-flex align-items-center" id="navbar-collapse">
                <!-- Search -->
                <div class=" navbar-nav align-items-center">
                  <h4 class="fw-bold py-3 second margin cancelMargin">Aprobación de presupuesto</h4>
                </div>
                <!-- /Search -->
                <div class="navbar-nav  ms-auto ">
                  <button style="margin-top: 0px;" class="btn cambiarMarca btn-primary btn-block"
                    onclick="{! c.mostrarCambiarMarca }"> Cambiar marca </button>
                </div>
              </div>
              <div class="bannercontainer">
                <aura:if isTrue="{!v.marcaSelected == 'BMW'}">
                  <img src="{!$Resource.bannerBmwS2}" alt="BMW Banner" class="banner-image-mw" />
                  <!-- <img src="{!$Resource.BMWCar}" alt="BMWLogo" class="banner-image-mw" /> -->
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'MINI'}">
                  <img src="{!$Resource.bannerMINIS2}" alt="BMWLogo" class="banner-image-mw" />
                </aura:if>
                <aura:if isTrue="{!v.marcaSelected == 'Motorrad'}">
                  <img src="{!$Resource.MotoCar}" alt="BMWLogo" class="banner-image-mw" />
                </aura:if>
              </div>
              <div class="slds-m-around_xx-large">
                <aura:if isTrue="{!v.isModalChangeMarca}">
                  <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true"
                    aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                    <div class="slds-modal__container">
                      <header class="slds-modal__header">
                        <div id="creandocita1_">
                          <span class="citation-message"> Estas en {!v.marcaSelected} </span> <br />
                          <div class="cambio-marca">
                            <b>¿Quieres cambiar?: </b>
                            <lightning:combobox class="form-control" id="checkMarcas" name="general"
                              placeholder="Marcas" options="{! v.marcasPagina }"
                              onchange="{! c.handleOnChangeSelectedMarca }" />
                            <br />
                          </div>
                        </div>
                        <div id="creandocita2_" style="padding-top:2px">
                          <lightning:button variant="neutral" label="Volver" title="Volver"
                            onclick="{! c.cerrarCambiarMarca }" />

                          <lightning:button variant="brand" label="Presiona para confirmar"
                            title="Presiona para confirmar" onclick="{! c.handleAceptarMarca }" />
                        </div>

                      </header>

                    </div>
                  </section>
                  <div class="slds-backdrop slds-backdrop_open"></div>
                </aura:if>
              </div>
              <!-- <img src="{!$Resource.BMWCar}" alt="BMWLogo" class="banner-image" /> -->
              <h2 class="h2-title">Número de orden: {!v.numOrden}</h2>
            
              <div class="middle-section-top">
                <div>
                  <h2>Información del propietario</h2>
                  <div class="middle-section-child-top first">
                    <p><strong>Propietario: </strong>{!v.propietario}</p>
                    <p><strong>Contacto: </strong>{!v.contacto}</p>
                    <p><strong>Cédula: </strong>{!v.cedula}</p>
                    <p><strong>Teléfono: </strong>{!v.telefono}</p>
                    <p><strong>Correo: </strong>{!v.correo}</p>
                    <p><strong>Fecha de entrada: </strong>{!v.fechaEntrada}</p>
                  </div>
                </div>
                <div>
                  <h2>Información del vehículo</h2>
                  <div class="middle-section-child-top">
                    <p><strong>Placa: </strong>{!v.placa}</p>
                    <p><strong>Marca: </strong>{!v.marca}</p>
                    <p><strong>Modelo: </strong>{!v.modelo}</p>
                    <p><strong>Año: </strong>{!v.anio}</p>
                    <p><strong>VIN: </strong>{!v.vin}</p>
                    <p><strong>Kilometraje: </strong>{!v.kilometraje}</p>
                    <!-- <p><strong>Combustible:</strong>{!v.combustible}</p> -->
                  </div>
                </div>

              </div>

              <div class="tabs-container2" style="margin-top: 35px;">
                <ul class="slds-accordion main-accordion2">
                  <li class="slds-accordion__list-item">
                    <section class="slds-accordion__section slds-is-open" style="background: #f9f9f996">
                      <div class="slds-accordion__summary" style="background-color: #efefef">
                        <h2 class="slds-accordion__summary-heading">
                          <button class="slds-button slds-button_reset slds-accordion__summary-action cust-btn-acc"
                            aria-controls="referenceId-4" aria-expanded="{!v.isOpen4}" onclick="{!c.toggleAccordion4}"
                            title="Estado del vehículo en el taller">
                            <span class="slds-accordion__summary-content">Estado del vehículo en el taller</span>
                            <!-- <lightning:icon iconName="utility:chevronright" alternativeText="Arrow" size="x-small"
                              title="x-small size" aria-hidden="true"
                              style="{!v.isOpen4 ? 'transform: rotate(0deg);' : 'transform: rotate(90deg);'}" /> -->
                          </button>
                        </h2>
                      </div>

                      <!-- <div class="slds-accordion__content" id="referenceId-4" style="{!v.isOpen4 ? 'display: none;' : 'display: block;'}"> -->
                      <div class="slds-accordion__content" id="referenceId-4" style="display: block;">

                        <div class="parent-timeline-container">
                          <div class="progress-indicator-title align-items-left">
                            <lightning:icon iconName="utility:success" alternativeText="Success!" variant="Success"
                              title="success variant" />
                            <h4>{!v.estadoActual}</h4>
                          </div>
                          <!-- <h2>Estado del vehículo en el taller</h2> -->
                          <div class="timeline-container">
                            <ul class="timeline">
                              <aura:iteration items="{!v.stages}" var="stage">
                                <li class="{!stage.class}">
                                  {!stage.Nombre_Mostrar__c}
                                </li>
                              </aura:iteration>
                            </ul>
                          </div>
                        </div>
                      </div>

                    </section>
                  </li>
                </ul>
              </div>

              <div class="info-top-section" style="margin-top: 40px;">
                <h2>Resumen de inspección</h2>
              </div>
              <div class="middle-section">
                <div class="middle-section-child">
                  <p style="color: #000;"><strong>Total Presupuesto</strong></p>
                  <p>{!v.currencyIso} {!v.cantidadPresupuesto}</p>
                  <!-- <ui:outputText value="{!v.totalPresupuesto}"/> -->
                </div>
                <div class="middle-section-child">
                  <p style="color: #000;"><strong>Total Aprobado</strong></p>
                  <p>{!v.currencyIso} {!v.cantidadAprobado}</p>
                  <!-- <ui:outputText value="{!v.totalAprobado}"/> -->
                </div>
                <div class="middle-section-child">
                  <p style="color: #000;"><strong>Puntos Seleccionados</strong></p>
                  <p> {!v.cantidadVerdes} / {!v.cantidadTotal} </p>
                  <!-- <ui:outputText value="{!v.ptsSeleccionados}"/> -->
                </div>
              </div>

              <div class="acordions-container">
                <!-- <p>Estado del toggle: {!v.isChecked}</p> -->
                <!-- <div class="toggle-container">
                  <h2>Aprobar todo</h2>
                  <label class="switch">
                    <input type="checkbox" checked="{!v.isChecked}" onchange="{!c.handleToggleChange}">
                    </input>
                    <span class="slider round"></span>
                  </label>
                </div> -->

                <div class="tabs-container">
                  <div class="number-container" style="background: #ee1c25;">
                    <span>{!v.cantidadNecesario}</span>
                  </div>
                  <ul class="slds-accordion main-accordion">
                    <li class="slds-accordion__list-item">
                      <section class="slds-accordion__section slds-is-open">
                        <div class="slds-accordion__summary" style="background-color: #efefef">
                          <h2 class="slds-accordion__summary-heading">
                            <button class="slds-button slds-button_reset slds-accordion__summary-action cust-btn-acc"
                              aria-controls="referenceId-3" aria-expanded="{!v.isOpen3}" onclick="{!c.toggleAccordion3}"
                              title="Necesario">
                              <span class="slds-accordion__summary-content">
                                Urgente - {!v.currencyIso} {!v.totalNecesario}
                              </span>
                              <lightning:icon iconName="utility:chevronright" alternativeText="Arrow" size="x-small"
                                title="x-small size" aria-hidden="true"
                                style="{!v.isOpen3 ? 'transform: rotate(0deg);' : 'transform: rotate(90deg);'}" />
                            </button>
                          </h2>
                        </div>

                        <div class="slds-accordion__content" id="referenceId-3"
                          style="{!v.isOpen3 ? 'display: none;' : 'display: block;'}">


                        </div>

                      </section>
                    </li>
                  </ul>
                </div>

                <div class="tabs-container">
                  <div class="number-container" style="background: #dbb013;">
                    <span>{!v.cantidadSugerido}</span>
                  </div>
                  <ul class="slds-accordion main-accordion">
                    <li class="slds-accordion__list-item">
                      <section class="slds-accordion__section slds-is-open">
                        <div class="slds-accordion__summary" style="background-color: #efefef">
                          <!-- <h2 class="slds-accordion__summary-heading">
                            <button class="slds-button slds-button_reset slds-accordion__summary-action cust-btn-acc"
                              aria-controls="referenceId-2" aria-expanded="{!v.isOpen2}" onclick="{!c.toggleAccordion2}"
                              title="Recomendado">
                              <span class="slds-accordion__summary-content">Sugerido</span>
                              <lightning:icon iconName="utility:chevronright" alternativeText="Arrow" size="x-small"
                                title="x-small size" aria-hidden="true"
                                style="{!v.isOpen2 ? 'transform: rotate(0deg);' : 'transform: rotate(90deg);'}" />
                            </button>
                          </h2> -->
                          <h2 class="slds-accordion__summary-heading">
                            <button class="slds-button slds-button_reset slds-accordion__summary-action cust-btn-acc"
                              aria-controls="referenceId-2" aria-expanded="{!v.isOpen2}" onclick="{!c.toggleAccordion2}"
                              title="Sugerido">
                              <span class="slds-accordion__summary-content">
                                Próximo - {!v.currencyIso} {!v.totalSugerido}
                              </span>
                              <lightning:icon iconName="utility:chevronright" alternativeText="Arrow" size="x-small"
                                title="x-small size" aria-hidden="true"
                                style="{!v.isOpen2 ? 'transform: rotate(0deg);' : 'transform: rotate(90deg);'}" />
                            </button>
                          </h2>
                        </div>

                        <div class="slds-accordion__content" id="referenceId-2"
                          style="{!v.isOpen2 ? 'display: none;' : 'display: block;'}">


                        </div>

                      </section>
                    </li>
                  </ul>
                </div>

                <div class="tabs-container">
                  <div class="number-container" style="background: #009244;">
                    <span>{!v.cantidadRecomendado}</span>
                  </div>
                  <ul class="slds-accordion main-accordion">
                    <li class="slds-accordion__list-item">
                      <section class="slds-accordion__section slds-is-open">
                        <div class="slds-accordion__summary" style="background-color: #efefef">

                          <h2 class="slds-accordion__summary-heading">
                            <button class="slds-button slds-button_reset slds-accordion__summary-action cust-btn-acc"
                              aria-controls="referenceId-1" aria-expanded="{!v.isOpen}" onclick="{!c.toggleAccordion}"
                              title="Recomendado">
                              <span class="slds-accordion__summary-content">
                                Sugerido - {!v.currencyIso} {!v.totalRecomendado}
                              </span>
                              <lightning:icon iconName="utility:chevronright" alternativeText="Arrow" size="x-small"
                                title="x-small size" aria-hidden="true"
                                style="{!v.isOpen ? 'transform: rotate(0deg);' : 'transform: rotate(90deg);'}" />
                            </button>
                          </h2>
                        </div>
                        <div class="slds-accordion__content" id="referenceId-1"
                          style="{!v.isOpen ? 'display: none;' : 'display: block;'}">
                          <!-- <div class="points-container">
                            <div class="points-container-child">
                              <p><strong>Punto 1</strong></p>
                              <div class="points-sec-container">
                                <label>CRC 200</label>
                                <span>Aprobado</span>
                              </div>
                            </div>
                            <ul class="list-container">
                              <li>Prueba</li>
                              <li>Prueba 2</li>
                              <li>Prueba 3</li>
                            </ul>
                          </div> -->
                        </div>
                      </section>
                    </li>
                  </ul>
                </div>
                <aura:if isTrue="{!v.disabledButon}">
                  <button onclick="{!c.openShowInsc}" style="width: 40%; margin-inline: auto;"
                    class="btn cambiarMarca btn-primary btn-block" disabled="true">
                    Confirmar
                  </button>
                  <aura:set attribute="else">
                    <button onclick="{!c.openShowInsc}" style="width: 40%; margin-inline: auto;"
                      class="btn cambiarMarca btn-primary btn-block" disabled="false">
                      Confirmar
                    </button>
                  </aura:set>
                </aura:if>
              </div>

            </div>
          </div>
          <aura:if isTrue="{!v.isModalInsc}">
            <div class="slds-m-around_xx-large">
              <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true"
                aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container cust-modal">
                  <button class="slds-button slds-button_icon slds-modal__close" title="Close"
                    onclick="{!c.closeShowInsc}">
                    X
                  </button>
                  <div class="slds-modal__header custom-modal" style="padding: 20px 0;">
                    <h1 style="font-size: 20px;max-width:80%;margin:0 auto; text-align:center">
                      Agradecemos su confianza en nuestros servicios
                    </h1>
                    <p style="margin-top: 18px;font-size:15px">
                      A continuación un resumen de los trabajos a realizar
                    </p>
                    <div style="margin-top: 18px;">
                      <h2 class="aprov-title" title="Producto">Total aprobado: {!v.currencyIso} {!v.cantidadAprobado}
                      </h2>
                      <br />
                      <h2 class="aprov-title" title="Producto">Puntos aprobados:</h2>
                      <!-- Necesario Category -->
                      <ol class="list-body">
                        <div class="aprov-container">
                          <h3 class="aprov-content">Urgente</h3>
                          <h3 class="aprov-content">Total: {!v.currencyIso} {!v.totalNecesarioFinal}</h3>
                        </div>
                        <aura:iteration items="{!v.approvedNecesario}" var="nombre">
                          <li>{!nombre}</li>

                        </aura:iteration>
                      </ol>

                      <!-- Sugerido Category -->
                      <ol class="list-body">
                        <div class="aprov-container">
                          <h3 class="aprov-content">Próximo</h3>
                          <h3 class="aprov-content">Total: {!v.currencyIso} {!v.totalSugeridoFinal}</h3>
                        </div>
                        <aura:iteration items="{!v.approvedSugerido}" var="nombre">
                          <li>{!nombre}</li>
                        </aura:iteration>
                      </ol>

                      <!-- Recomendado Category -->
                      <ol class="list-body">
                        <div class="aprov-container">
                          <h3 class="aprov-content">Sugerido</h3>
                          <h3 class="aprov-content">Total: {!v.currencyIso} {!v.totalRecomendadoFinal}</h3>
                        </div>
                        <aura:iteration items="{!v.approvedRecomendado}" var="nombre">
                          <li>{!nombre}</li>
                        </aura:iteration>
                      </ol>

                    </div>
                    <p style="font-size: 15px;max-width:80%;margin-inline: auto; margin-top:18px; text-align:center">
                      Una vez confirmados los trabajos no se podrán desaprobar
                    </p>
                    <p style="font-size: 13px;max-width:80%;margin-inline: auto; text-align:center">
                      *Los precios incluyen IVA.
                    </p>
                    <button onclick="{!c.handleButtonClick}" style="width: 40%; margin-inline: auto;"
                      class="custom-send btn btn-primary btn-block">
                      Confirmar
                    </button>
                  </div>
                </div>
              </section>
              <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
          </aura:if>

          <aura:if isTrue="{!v.isActive}">
            <div class="slds-m-around_xx-large">
              <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-02" aria-modal="true"
                aria-describedby="modal-content-id-2" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container modal__c">
                  <button class="slds-button slds-button_icon slds-modal__close" title="Close"
                    onclick="{!c.closeShowMedia}">
                    X
                  </button>
                  <div class="slds-modal__header custom-modal">
                    <div class="container-media">
                      <h1>Evidencias del mecánico - {!v.tipoTrabajoNombre}</h1>
                      <div id="mediaContainer" class="image-grid-container">
                        <div id="mainWorkContainer" class="image-grid">

                        </div>
                        <div id="subWorkContainer" class="image-grid-container">

                        </div>
                      </div>
                      <div id="galleryModal" class="modal" style="display: none;">
                        <span id="closeModal" class="close">&times;</span>
                        <img id="galleryImage" class="modal-content" />
                        <video id="galleryVideo" class="modal-content" controls="controls" style="display: none;" />
                        <div id="caption" class="caption"></div>
                        <div class="modal-nav">
                          <span id="prevImage" class="nav-button">&#10094;</span>
                          <span id="nextImage" class="nav-button">&#10095;</span>
                        </div>
                      </div>

                      <!-- <div class="section__c">
                        <div class="section-title_c">CAMBIO DE LLANTAS</div>
                        <div class="image-grid">
                          <div class="image-item">
                            <img src="{!v.foto1}" alt="Prueba IMG" />
                          </div>
                          <div class="image-item">
                            <video width="250" controls="controls">
                              <source src="{!v.testVideoUrl}" type="video/mp4" />
                            </video>
                          </div>

                        </div>
                      </div> -->

                      <!-- <aura:if isTrue="{! v.loaded }">
                        <div id="mediaContainer" class="image-grid"></div>
                        <div id="galleryModal" class="modal" style="display: none;">
                          <span id="closeModal" class="close">&times;</span>
                          <img id="galleryImage" class="modal-content"/>
                          <video id="galleryVideo" class="modal-content" controls="controls" style="display: none;"/>
                          <div id="caption" class="caption"></div>
                          <div class="modal-nav">
                            <span id="prevImage" class="nav-button">&#10094;</span>
                            <span id="nextImage" class="nav-button">&#10095;</span>
                          </div>
                        </div>
                        <aura:set attribute="else">
                            <lightning:spinner alternativeText="Loading" />
                        </aura:set>
                      </aura:if> -->
                    </div>

                  </div>
                </div>
              </section>
              <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
          </aura:if>

          <aura:if isTrue="{!v.isModalNewCase}">
            <div class="slds-m-around_xx-large">

              <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true"
                aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                  <header class="slds-modal__header">

                    <div id="">
                      <button class="slds-button slds-button_icon slds-modal__close" title="Close"
                        onclick="{!c.closeModelCase}">
                        X
                      </button>
                      <br />
                      <lightning:input type="textarea" label="¿En que podemos ayudarle?" class="slds-textarea"
                        value="{!v.descripcionCase}" />
                      <br />
                    </div>
                    <br />
                    <div id="creandocita2_" style="padding-top:2px">
                      <lightning:button variant="brand" label="Confirmar" title="Confirmar" onclick="{!c.createCase}" />
                    </div>

                  </header>

                </div>
              </section>
              <div class="slds-backdrop slds-backdrop_open"></div>
            </div>
          </aura:if>

          <div class="slds-m-around_xx-large">
            <aura:if isTrue="{!v.isModalOpenSoporte}">

              <!-- Modal/Popup Box starts here-->
              <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true"
                aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                  <!-- Modal/Popup Box Header Starts here-->
                  <header class="slds-modal__header">

                    <div id="">
                      <button style="top:0 !important;right: 0 !important "
                        class="slds-button slds-button_icon slds-modal__close" title="Close"
                        onclick="{!c.closeSoporte}">
                        X
                      </button>
                      <!--title="Asistencia en línea." <span class="citation-message"> Tu cita ha sido creada. </span> -->
                      <br />
                      <span style="margin-top: 30px;" class="citation-message"> Asistencia en
                        línea. </span>
                      <br />

                      <button type="button" style="background-color: #25d366 !important; margin-top:15px"
                        class="btn btn-success"><a style="color:#ffffff !important;"
                          href="https://api.whatsapp.com/send?phone=50687954888&amp;text=Soporte%20Modulo%20de%20Autogestión"
                          target="_blank">WhatsApp</a></button>
                      <br />
                    </div>
                    <br />
                    <div id="creandocita2_" style="padding-top:2px">
                    </div>

                  </header>

                </div>
              </section>
              <div class="slds-backdrop slds-backdrop_open"></div>
            </aura:if>
          </div>

          <!-- Inicia terminos y condiciones -->
          <div class="slds-m-around_xx-large" id="terminosYcondiciones" style="display:none">

            <!-- Modal/Popup Box starts here-->
            <section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true"
              aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open">
              <div class="slds-modal__container">
                <!-- Modal/Popup Box Header Starts here-->
                <header class="slds-modal__header">

                  <div class="terms-container">
                    <div style="height: 300px; overflow: scroll;">
                      <p><strong>TÉRMINOS Y CONDICIONES CITAS EN
                          LINEA / ONLINE APPOINTMENT TERMS AND
                          CONDITIONS</strong></p>

                      <p><strong>1. Los Servicios /
                          Services:</strong></p>
                      <p>Los productos y servicios, en adelante
                        denominados los "Servicios," se
                        proporcionan a través de Red Motors S.A
                        o cualquiera de sus empresas
                        subsidiarias que formen parte del mismo
                        grupo de interés económico mediante
                        nuestras plataformas digitales en
                        adelante denominado como “La
                        plataforma.” El uso de nuestros
                        Servicios implica la aceptación de estas
                        condiciones. Por favor, lea y revise
                        atentamente los Términos y Condiciones
                        de uso y nuestra Política de Privacidad
                        antes de utilizar cualquier Servicio en
                        línea de Red Motors S.A. Si no está de
                        acuerdo con estas condiciones, no podrá
                        agendar citas para utilizar nuestros
                        servicios.</p>

                      <p><strong>2. La Plataforma / The
                          Platform:</strong></p>
                      <p>La plataforma brinda distintos Servicios
                        a personas físicas y/o jurídicas, en
                        adelante denominadas “Usuario.” Por
                        Usuario deberá entenderse cualquier
                        persona que emplea los servicios o
                        productos de la plataforma. Red Motors
                        S.A se reserva el derecho de realizar
                        modificaciones a estos términos y
                        condiciones, y será su responsabilidad
                        mantenerse informado al respecto.</p>

                      <p><strong>3. Términos y Condiciones de la
                          Plataforma SimplyBook / SimplyBook
                          Platform Terms and
                          Conditions:</strong></p>
                      <p>Utilizamos SimplyBook como plataforma de
                        reservas, con lo que también aceptamos
                        los términos y condiciones de la
                        plataforma <a href="https://simplybook.me/en/terms-and-conditions#tab-for-clients"
                          target="_blank">SimplyBook Terms and
                          Conditions</a>. Para aclarar
                        cualquier consulta relacionada con este
                        tema, favor enviarnos un email a
                        servicioalclientebmw@redmotorscr.com.
                      </p>

                      <p><strong>4. Contenido y Derechos de
                          Propiedad Intelectual / Content and
                          Intellectual Property
                          Rights:</strong></p>
                      <p>Las fotografías de los productos muestran
                        sus colores reales, sin embargo, el
                        usuario puede verlos diferente según la
                        calibración de su monitor. Por lo tanto,
                        no podemos garantizar que los colores de
                        los artículos sean idénticos a los
                        mostrados en tu pantalla. Es
                        indispensable que el usuario lea
                        detenidamente la descripción del
                        artículo antes de proceder con la
                        compra.</p>

                      <p>En el caso de que un usuario postee o
                        envíe cualquier contenido a nuestro
                        sitio web o a nuestras redes sociales,
                        estaría permitiendo a Red Motors S.A.
                        utilizar dicho material de manera
                        gratuita, en la forma que considere
                        conveniente; cediendo así cualquier
                        derecho de imagen y/o audio/texto que en
                        él aparezca. Además, el usuario
                        garantiza que dicho contenido es de su
                        propiedad o bien que cuenta con los
                        derechos de uso de este. Red Motors
                        S.A., podrá editar o eliminar a su
                        discreción, cualquier contenido o
                        actividad posteada por el usuario. Todo
                        el contenido del sitio web es propiedad
                        de Red Motors S.A.</p>

                      <p><strong>5. Política de Cambios / Change
                          Policy:</strong></p>
                      <p>Una vez agendada la cita, si desea
                        cambiarla o cancelarla agradecemos
                        comunicarse con nosotros al 2547-5000 a
                        la brevedad para poderle atender.</p>
                      <p>Los servicios de diagnóstico serán
                        atendidos solamente en la sucursal de
                        Red Motors S.A de La Uruca, estos
                        servicios se refieren a:</p>
                      <ul>
                        <li>Revisar fugas de Aceite</li>
                        <li>Revisar vibraciones o Sonidos en
                          Carrocería; Sonidos de Suspensión;
                          Sonidos en el Motor.</li>
                        <li>Calentamiento en el Motor</li>
                        <li>Diagnóstico de problemas en A/C</li>
                        <li>Diagnóstico de Motores</li>
                        <li>Diagnósticos para RTV</li>
                        <li>Diagnóstico de Sistema Eléctrico
                        </li>
                        <li>Reparaciones mayores del Motor</li>
                        <li>Revisión de luces encendidas en el
                          panel.</li>
                      </ul>
                    </div>
                    <br />

                    <lightning:input aura:id="boxPack" type="checkbox"
                      label="He leído y acepto los Términos y Condiciones" onchange="{!c.setVisible}" required="true" />

                    <br />

                    <lightning:button variant="brand" aura:id="btnAceptar" label="Aceptar" title="Aceptar"
                      disabled="true" onclick="{! c.closeModalTerminos }" />
                  </div>
                </header>

              </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>

          </div>
          <!-- Termina terminos y condiciones  -->

          <!-- <footer style="position: sticky; bottom:10px" class="content-footer footer bg-footer-theme"> -->
          <footer class="content-footer footer bg-footer-theme">
            <div class="container-xxl d-flex flex-wrap justify-content-between py-2 flex-md-row flex-column">
              <div class="mb-2 mb-md-0">
                © 2024. Comunidad RedMotors. By PortalNet.
              </div>
              <div><a onclick="{! c.mostrarTerminos }">Terminos y condiciones</a></div>
            </div>
          </footer>
          <div class="content-backdrop fade"></div>
        </div>
      </div>
    </div>
    <div id="overlayMenu" onclick="{! c.hideMenu }" class="layout-overlay layout-menu-toggle"></div>
    <!-- Desktop -->

    <button onclick="{!c.openModalCase}" class="consulta-btn" aria-label="Abrir chat de consultas">
      <img src="{!$Resource.chatImage}" />
      <span class="consulta-btn-text">Consultas</span>
    </button>

    <!-- Mobile -->

    <!-- <button onclick="{!c.openModalCase}" class="consulta-btn" aria-label="Abrir chat de consultas">
      <img src="{!$Resource.chatImage}"/>
      <span class="consulta-btn-text">Consultas</span>
    </button> -->

  </body>

  </html>
</aura:component>