    @AuraEnabled(Cacheable = true)
    public static String getImagen(Id recordId) {
        List<Asset> lstAsset = [Select Id,Modelo_Nvo2__c, AccountId From Asset Where Id =:recordId];
        String modeloActual = lstAsset[0].Modelo_Nvo2__c;
        String modeloBuscar = '';
        if (modeloActual.contains(' ')) {
            // Extract the part before the space
            modeloBuscar = modeloActual.substringBefore(' ');
        } else {
            // Return the entire string if no space is found
            modeloBuscar = modeloActual;
        }
        System.debug(modeloBuscar);
		String modeloTodos = '%' + modeloBuscar + '%';
        List<Document> lstCoches = [SELECT Name, Id FROM Document WHERE DeveloperName like :modeloTodos AND Type = 'PNG' LIMIT 1];
        String idImagen = '';
        if(lstCoches.size()>0){
            idImagen = lstCoches[0].Id;
        }
        return idImagen;
    }

    @InvocableMethod(label='Obtener Imagen Vehiculo' description='Busca la url de la imagen' category='Asset')
    public static List<String> obtenerUrlImagen(List<String> idCoche){
        List<String> retorno = new List<String>();
        String vehiculoABuscar = idCoche[0];
        List<Asset> lstAsset = [Select Id,Modelo_Nvo2__c, AccountId From Asset Where Id =:vehiculoABuscar];
        String modeloActual = lstAsset[0].Modelo_Nvo2__c;
        String modeloBuscar = '';
        try {
            if (modeloActual.contains(' ')) {
                // Extract the part before the space

                modeloBuscar = '%' + modeloActual.substringBefore(' ') + '%';
            } else {
                // Return the entire string if no space is found
                modeloBuscar = '%' + modeloActual + '%';
            }
            
            List<Document> lstCoches = [SELECT Name, Id FROM Document WHERE Name like :modeloBuscar AND Type = 'PNG' LIMIT 1];
            String idImagen = '';
            if(lstCoches.size()>0){
                idImagen = lstCoches[0].Id;
            }
            retorno.add(idImagen);
        } catch (Exception e) {
            // Manejo de excepciones
            retorno.add('Error: ' + e.getMessage());
        }
        return retorno;
    }

    @AuraEnabled(Cacheable = true)
    public static List<Object> getAssets(Id recordId) {
        List<Asset> lstAsset = [Select Id, AccountId,Marca_Nvo__c,Modelo_Nvo2__c,Anio__c From Asset Where Id =:recordId];
        String cuentaActual = lstAsset[0].AccountId;
        List<Asset> lstCoches = [Select Id,Name,Marca_Nvo__c,Modelo_Nvo2__c,Anio__c From Asset Where AccountId =:cuentaActual];
        return lstCoches;
    }
    
    @AuraEnabled(Cacheable = true)
    public static List<Object> getUsuarioComunidad(Id recordId) {
        List<Asset> lstAsset = [Select Id, AccountId,Marca_Nvo__c,Modelo_Nvo2__c,Anio__c From Asset Where Id =:recordId];
        String cuentaActual = lstAsset[0].AccountId;
        List<Account> lstCuentas = [Select Id,CorreoElectronicoEmpresarial__c,personEmail From Account Where Id=:cuentaActual];
        String nomrbeUsuario = 'vacio';
        if(lstCuentas[0].CorreoElectronicoEmpresarial__c != null){
            nomrbeUsuario = '%' + lstCuentas[0].CorreoElectronicoEmpresarial__c + '%' ;
        }else if(lstCuentas[0].personEmail != null){
            nomrbeUsuario = '%' + lstCuentas[0].personEmail +  '%' ;
        }
        
        List<User> lstUser = [Select Id From User Where username Like :nomrbeUsuario AND Profile.Name like '%Community%'];
        return lstUser;
    }
    
