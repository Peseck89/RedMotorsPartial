    @AuraEnabled
    public static void updateComentario(Id recordId, String comentario) {
        Opportunity opp = [SELECT Id, Observaciones_cliente__c FROM Opportunity WHERE Id = :recordId LIMIT 1];
        opp.Observaciones_cliente__c = comentario;
        update opp;
    }

    @AuraEnabled(Cacheable = true)
    public static List<Event> getProximaVisita(Id recordId) {
         // Query to get the closest upcoming event
         List<Event> lstEvento = [SELECT Id, StartDateTime, StartDateTimeF__c 
         FROM Event 
         WHERE Activo__c =: recordId 
         AND Estado__c = null 
         AND StartDateTime >= TODAY 
         ORDER BY StartDateTime ASC 
         LIMIT 1];
        return lstEvento;
    }

    @AuraEnabled(Cacheable = true)
    public static List<Object> getHistorialInfo(Id recordId) {
        List<Historial_Fechas__c> lstHistorial = [SELECT Id,TipoDeFecha__c,Fecha__c FROM Historial_Fechas__c WHERE Vehiculo__c =: recordId Order by Fecha__c DESC];
        List<Event> lstEventos = [Select Id,ActivityDate,Asesor__c,Asesor__r.FirstName from Event Where Activo__c =:recordId AND Asesor__r.FirstName != 'Calendario' and owner.FirstName = 'Calendario'];
        for(Event ev :lstEventos ){
            Historial_Fechas__c nuevaFecha = new Historial_Fechas__c();
            nuevaFecha.TipoDeFecha__c = 'Cita';
            nuevaFecha.Fecha__c = ev.ActivityDate;
            lstHistorial.add(nuevaFecha);
        }
           // Simple bubble sort implementation to sort lstHistorial by Fecha__c in descending order
        Integer n = lstHistorial.size();
        for (Integer i = 0; i < n; i++) {
            for (Integer j = 0; j < n - i - 1; j++) {
                if (lstHistorial[j].Fecha__c < lstHistorial[j + 1].Fecha__c) {
                    Historial_Fechas__c temp = lstHistorial[j];
                    lstHistorial[j] = lstHistorial[j + 1];
                    lstHistorial[j + 1] = temp;
                }
            }
        }

        return lstHistorial;
    }
    

