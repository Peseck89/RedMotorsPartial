    @AuraEnabled()
    public static String uploadFile(String base64Data, String fileName,String recordId) {
        String contentType = fileName.substring(fileName.lastIndexOf('.') + 1).toLowerCase();
        String fileExtension = contentType.equals('jpg') || contentType.equals('jpeg') ? 'jpg' : contentType;
        if (!contentType.equals('jpg') && !contentType.equals('jpeg') && !contentType.equals('png')) {
            throw new AuraHandledException('Unsupported file type.');
        }

        // Create a ContentVersion
        ContentVersion contentVersion = new ContentVersion();
        contentVersion.Title = fileName;
        contentVersion.PathOnClient = fileName;
        contentVersion.VersionData = EncodingUtil.base64Decode(base64Data);
        insert contentVersion;

        // Query the ContentDocumentId
        contentVersion = [SELECT ContentDocumentId FROM ContentVersion WHERE Id = :contentVersion.Id LIMIT 1];

        // Create a ContentDocumentLink to link the image to the Asset object
        ContentDocumentLink contentDocumentLink = new ContentDocumentLink();
        contentDocumentLink.ContentDocumentId = contentVersion.ContentDocumentId;
        contentDocumentLink.LinkedEntityId = recordId; // Replace with the actual Asset record ID
        contentDocumentLink.ShareType = 'I';
        contentDocumentLink.Visibility = 'AllUsers';
        insert contentDocumentLink;

        List<Asset> lstCoche = [Select Id,Image_URL__c From Asset Where Id =: recordId];
        if(lstCoche.size() > 0){
            
            lstCoche[0].Image_URL__c = '/sfc/servlet.shepherd/document/download/' + contentVersion.ContentDocumentId;
            update lstCoche;
        }

        return '/sfc/servlet.shepherd/document/download/' + contentVersion.ContentDocumentId;
    }

    @AuraEnabled(Cacheable = true)
    public static List<Event> getUltimaVisita(Id recordId) {
        List<Event> lstEvento = [Select Id,StartDateTime,StartDateTimeF__c From Event Where Activo__c =: recordId AND Estado__c = 'Asistió' Order by StartDateTime ASC LIMIT 1];
        return lstEvento;
    }

    @AuraEnabled(Cacheable = true)
    public static List<Opportunity> getUltimoComentario(Id recordId) {
        List<Opportunity> lstOpp = [Select Id,Observaciones_cliente__c, ConsecutivoOportunidad__c, Observaciones_negocio__c From Opportunity Where BMW_PlacaDeVehiculoOElVIN__c =: recordId Order by LastModifiedDate DESC LIMIT 1];
        return lstOpp;
    }

    @AuraEnabled(Cacheable = true)
