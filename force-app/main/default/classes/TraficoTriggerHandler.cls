	public TraficoTriggerHandler() {
		this.newInvMap = (Map<Id, Lead>) Trigger.newMap;
		this.newInvs = (List<Lead>) Trigger.New;
        this.oldInvs = (List<Lead>) Trigger.Old;
		this.oldInvMap = (Map<Id, Lead>) Trigger.oldMap;
        
	}

	public override void beforeInsert(){
		List<Lead> listLeadsTemp = new List<Lead>();
		System.debug('El lead es: '+newInvs);
		TraficoService.ObtenerListaPreciosW2L(newInvs);
		//TraficoService.ValidarListaPrecios(newInvs);
		TraficoService.ActualizarListaPreciosVigente(newInvs);
		for(Lead l : newInvs){
            System.debug('Entro Handler');
            //TriggerHelper.createSeguimiento(l.Email,newInvs);
			if(l.Rating == 'Neutro' && l.Web_to_Lead_Form__c){
				listLeadsTemp.add(l);
			}
		}
		if(!listLeadsTemp.isEmpty() && listLeadsTemp.size() > 0){
			TraficoService.actualizarCampannaWebToLead(newInvs);
		}
	}

	public override void beforeUpdate(){
		//TraficoService.ValidarListaPrecios(newInvs);
		TraficoService.ActualizarListaPreciosVigente(newInvs);

        //List<Lead> lstActuales = [Select id,LeadSource,OwnerId,Sucursal__c,Marca__c From lead Where Id in:newInvs];
        
        
        
	}

	public override void afterInsert(){
        // Verificar si el usuario actual es administrador
        Id userId =UserInfo.getUserId();
        List<User> lstUsuarios = [SELECT ProfileId, noValidar__c,Profile.Name FROM User WHERE Id = :UserInfo.getUserId() LIMIT 1];
        Boolean isAdmin = [SELECT ProfileId, noValidar__c,Profile.Name FROM User WHERE Id = :UserInfo.getUserId() LIMIT 1].Profile.Name == 'System Administrator';
        Boolean isEdecan = [SELECT ProfileId, noValidar__c,Profile.Name FROM User WHERE Id = :UserInfo.getUserId() LIMIT 1].Profile.Name == 'Recepcion Mixtos';
        if((!isAdmin && !isEdecan && lstUsuarios[0].noValidar__c != true) || lstUsuarios[0].noValidar__c != true) {
            if(newInvs[0].Ignorar_asignacion__c == false){
                leadOwnerAssignacion.setOwner(newInvs);
                LeadTriggerHandler.isAlreadyProcessed = true;
            }                              
        }
        
		System.debug('*** lead entrante **** ' + newInvs);
        if(newInvs.size() > 0) {
            if(newInvs[0].Marca__c == 'BMW' || newInvs[0].Marca__c == 'Indian' || newInvs[0].Marca__c == 'MINI' || newInvs[0].Marca__c == 'Motorrad' || newInvs[0].Marca__c == 'Polaris' || newInvs[0].Marca__c == 'Kawasaki'){
                
                TraficoService.enviarCotizacionCustom(newInvs);
            }else{
                TraficoService.EnviarCotizacion(newInvs);
            }
        }
	}

	public override void afterUpdate() {     
        Id userId = UserInfo.getUserId(); 
    
        // Check the static flag to prevent cyclic updates
        if (!LeadTriggerHandler.isAlreadyProcessed) {
            LeadTriggerHandler.isAlreadyProcessed = true; // Set the flag
    
            for (Lead trafico : newInvs) {
                if (oldInvs[0].ownerId != userId) {
                    leadOwnerAssignacion.setOwner(newInvs); 
                }
            }
            // Reset the flag after processing is complete
            LeadTriggerHandler.isAlreadyProcessed = false;
        }
    
            System.debug('*** metod after update *** ');
            Map<Id, Lead> convertedLeadsMap = new Map<Id, Lead>();
    
            for (Lead lead : newInvs) {
                if (lead.IsConverted != oldInvMap.get(lead.Id).IsConverted && lead.IsConverted) {
                    convertedLeadsMap.put(lead.Id, lead);
                }
            }
    
            if (!convertedLeadsMap.isEmpty()) {
                System.debug('**** metodo  ActualizaRecordType *** ');
                TraficoService.TransferirIntereses(convertedLeadsMap.values());
                RM_Lead_Trigger_Helper lth = new RM_Lead_Trigger_Helper();
                lth.setOpportunityRecordType(convertedLeadsMap.values());
                lth.identifyVehicleUsed(convertedLeadsMap, oldInvMap);
            }
    
            
    }
    
    
    
