    public static void sendMail(String EmailTempId, List<String> ToAddress, String orgWideEmail, String targetObjectId, List<Id> ids){
        List<Messaging.SingleEmailMessage> mails = new List<Messaging.SingleEmailMessage>();
        Messaging.SingleEmailMessage mail = new Messaging.SingleEmailMessage();
        mail.setTemplateId(EmailTempId); //Id of the Email Template
        mail.setToAddresses(ToAddress);
        mail.setWhatId(targetObjectId);
        mail.setTargetObjectId(targetObjectId); // Id of Contact or Lead or User
        mail.setSaveAsActivity(false);
        mail.setOrgWideEmailAddressId(orgWideEmail);  
        mail.setUseSignature(false);
        if (ids != null && ids.size()>0) {
           System.debug('ids dentro if: '+ids);
            mail.setEntityAttachments(ids);
        }
        
        mail.setTreatTargetObjectAsRecipient(false);
        mails.add(mail);           
        System.debug('mail: '+mail);
                System.debug('ids: '+ids);

        if (!Test.isRunningTest()) {
            //Messaging.sendEmail(new Messaging.SingleEmailMessage[] { mail });
            Messaging.SendEmailResult[] r = Messaging.sendEmail(mails);
        } 
    }


