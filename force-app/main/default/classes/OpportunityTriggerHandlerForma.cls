public with sharing class OpportunityTriggerHandlerForma {
    public static void handleRecibosUsados(List<Opportunity> newOpps, Map<Id, Opportunity> oldMap) {
        Set<Id> oppIds = new Set<Id>();
        
        // Identificar oportunidades con Envio_formalizacion_legal__c cambiado a true
        for (Opportunity opp : newOpps) {
            if (opp.Envio_formalizacion_legal__c == true && 
                oldMap.get(opp.Id).Envio_formalizacion_legal__c != true) {
                oppIds.add(opp.Id);
            }
        }
        
        if (oppIds.isEmpty()) return;
        
        // Obtener Record Types de ReciboUsado__c
        Map<String, RecordType> rtMap = OpportunityTriggerHandlerForma.getRecordTypes();
        Set<Id> autoRtIds = new Set<Id>{ rtMap.get('Automovil')?.Id };
        Set<Id> motoRtIds = new Set<Id>{ rtMap.get('Motocicleta')?.Id };
        
        // Recuperar y actualizar RecibosUsados__c
        List<ReciboUsado__c> recibosToUpdate = new List<ReciboUsado__c>();
        
        for (ReciboUsado__c recibo : [
            SELECT Id, RecordTypeId, Serecibevehiculo__c, Se_Recibe_Motocicleta__c, VehiculoRecibido__c 
            FROM ReciboUsado__c 
            WHERE Oportunidad__c IN :oppIds
            AND VehiculoRecibido__c = false
        ]) {
            if (autoRtIds.contains(recibo.RecordTypeId)) {
                recibo.Serecibevehiculo__c = true;
                recibo.VehiculoRecibido__c = true;
                recibosToUpdate.add(recibo);
            } else if (motoRtIds.contains(recibo.RecordTypeId)) {
                recibo.Se_Recibe_Motocicleta__c = true;
                recibo.VehiculoRecibido__c = true;
                recibosToUpdate.add(recibo);
            }
        }
        
        if (!recibosToUpdate.isEmpty()) {
            update recibosToUpdate;
        }
    }
    
    private static Map<String, RecordType> getRecordTypes() {
        Map<String, RecordType> rtMap = new Map<String, RecordType>();
        for (RecordType rt : [
            SELECT Id, DeveloperName 
            FROM RecordType 
            WHERE SObjectType = 'ReciboUsado__c'
            AND DeveloperName IN ('Automovil', 'Motocicleta')
        ]) {
            rtMap.put(rt.DeveloperName, rt);
        }
        return rtMap;
    }

