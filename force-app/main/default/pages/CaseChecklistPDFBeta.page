    <table style="font-size: 12px; font-family:sans-serif; width:100%;padding: 10px 20px;color:#333333;margin-top:-20px;">
        <tr>
            <td>
                <span style="line-height: 0.428571;color: #333333;text-align: left;font-weight: bold;font-size: 16px;font-family:Arial, Helvetica, sans-serif;margin-top:-5px">Información del cliente:</span>
            </td>
            <td>
                <span style="line-height: 0.428571;color: #333333;text-align: left;font-weight: bold;font-size: 16px;font-family:Arial, Helvetica, sans-serif;margin-top:-5px">Información del vehículo: </span>
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Propietario:&nbsp;</span>
                <apex:outputField value="{!case.Account.Name}" />&nbsp;&nbsp;
                  <apex:repeat value="{!cambioPropietario}" var="cp">
                    <apex:outputText value="Pendiente de actualización" 
                     rendered="{!cp.Estado__c = 'Pendiente'}"
                     style="font-weight:bold"/>
                  </apex:repeat>
            </td>
            <td>
                <span style="font-weight:bold">Matricula:&nbsp;</span>
                <apex:outputField value="{!case.Asset.numeroDePlaca__c}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Contacto:&nbsp;</span>
                <apex:outputField value="{!case.Contact.Name}" />
            </td>
            <td>
                <span style="font-weight:bold">Marca:&nbsp;</span>
                <apex:outputField value="{!case.Asset.marca__c}" /> 
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Cédula:&nbsp;</span>
                <apex:outputField value="{!Case.Contact.Cedula__c}"
    		       rendered="{!Case.ContactId != null && Case.Contact.Cedula__c != null && Case.Contact.Cedula__c != ''}" />
		        <apex:outputField value="{!Case.Account.Cedula__c}"
    		       rendered="{!Case.ContactId == null || Case.Contact.Cedula__c == null || Case.Contact.Cedula__c == ''}" />
            </td>
            <td>
                <span style="font-weight:bold">Vehículo:&nbsp; </span>
                <apex:outputField value="{!case.Asset.Tipo_de_veh_culo__c}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Teléfono:&nbsp; </span>
                <apex:outputField rendered="{! case.Contact.id != null}" value="{!case.Contact.Phone}" />
                <apex:outputField rendered="{! case.Contact.id == null}" value="{!case.Account.Phone}" />
            </td>
            <td>
                <span style="font-weight:bold">VIN:</span> &nbsp;
                <apex:outputField value="{!case.Asset.NumeroDeChasis__c}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">E-mail:&nbsp;</span>
                <apex:outputField rendered="{! case.Contact.id != null}" value="{!case.Contact.Email}" />
                <apex:outputField rendered="{! case.Contact.id == null && case.Account.RecordType.Name == 'Cuenta personal'}" value="{!case.Account.PersonEmail}" />
                <apex:outputField rendered="{! case.Contact.id == null && case.Account.RecordType.Name == 'Cuenta Empresarial'}" value="{!case.Account.CorreoElectronicoEmpresarial__c}" />
            </td>
            <td>
                <apex:outputtext rendered="{!if(case.Asset.Tipo_de_veh_culo__c=='Mula' || case.Asset.Tipo_de_veh_culo__c=='Cuadraciclo' ,true,false)}">
                <span style="font-weight:bold" >Horas de uso:&nbsp;</span>
                </apex:outputtext>
          <apex:outputtext rendered="{!if(case.Asset.Tipo_de_veh_culo__c!='Mula' && case.Asset.Tipo_de_veh_culo__c!='Cuadraciclo' ,true,false)}">
                <span style="font-weight:bold" >Kms:&nbsp;</span>
                </apex:outputtext>
                <apex:outputText value="{0,number, ###,###}">
                    <apex:param value="{!kilometros}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Ubicación:</span> &nbsp;
                <apex:repeat value="{!Ubi}" var="item">
                    <apex:outputField value="{!item.ServiceTerritoryId}" />
                    <br/>
                </apex:repeat>
            </td>
            <td>
                <span style="font-weight:bold">Cód. Modelo:&nbsp; </span>
                <apex:outputField value="{!case.Asset.modelo__c}" />
            </td>
        </tr>
        <tr>
