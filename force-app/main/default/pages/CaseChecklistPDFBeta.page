            </td>
            <td>
                <span style="font-weight:bold">Combustible:</span>&nbsp;
                <apex:outputField value="{!case.Asset.Combustible__c}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Fecha de entrada:&nbsp;</span>
