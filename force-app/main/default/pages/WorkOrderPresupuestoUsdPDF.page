                <span style="font-weight:bold">Cuenta de facturación:&nbsp;</span>
                <apex:outputField value="{!worder.Cuenta_de_Facturacion__r.Name}" />
		        
            </td>
            <td>
                <span style="font-weight:bold">Modelo:&nbsp;</span>
                <apex:outputField value="{!worder.Asset.modelo__c}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Cédula:&nbsp;</span>
                <apex:outputField value="{!worder.Contact.Cedula__c}"
    		       rendered="{!worder.ContactId != null && worder.Contact.Cedula__c != null && worder.Contact.Cedula__c != ''}" />
		        <apex:outputField value="{!worder.Account.Cedula__c}"
    		       rendered="{!worder.ContactId == null || worder.Contact.Cedula__c == null || worder.Contact.Cedula__c == ''}" />
            </td>
            <td>
                <span style="font-weight:bold">Año Modelo:&nbsp;</span>
                <apex:outputField value="{!worder.Asset.Anio__c}" /> </td>
            
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Tel. Propietario:&nbsp;</span>
                <apex:outputField value="{!worder.Contact.Phone}"
    		       rendered="{!worder.ContactId != null && worder.Contact.Phone != null && worder.Contact.Phone != ''}" />
		        <apex:outputField value="{!worder.Account.Phone}"
    		       rendered="{!worder.ContactId == null || worder.Contact.Phone == null || worder.Contact.Phone == ''}" />
            </td>
            <td>
                <span style="font-weight:bold">Tipo:&nbsp; </span>
                <apex:outputField value="{!worder.Asset.Account.Type}" />
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Tel. Movil:&nbsp;</span>
                <apex:outputField value="{!worder.Asset.Account.PersonMobilePhone}" />
            </td>
            <td>
                <span style="font-weight:bold">Kms:</span> &nbsp;
                <apex:outputText value="{0,number, ###,###}">
                    <apex:param value="{!kilometros}" />
                </apex:outputText>
            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Propietario:&nbsp; </span>{!worder.Asset.Account.Name}&nbsp;&nbsp;
                <apex:repeat value="{!cambioPropietario}" var="cp">    
                   <apex:outputText value="Pendiente de actualización" 
                     rendered="{!cp.Estado__c = 'Pendiente'}"
                     style="font-weight:bold"/>
                   </apex:repeat>
            </td>
            <td>
                <span style="font-weight:bold">Horas uso:&nbsp;</span>
