            </td>
        </tr>
        <tr>
            <td>
                <span style="font-weight:bold">Fecha Apertura:&nbsp; </span>
                <apex:outputField value="{!worder.CreatedDate}" />
            </td>
            
        </tr>

        <tr>
            <td colspan="2">
                <span style="font-weight:bold">Descripción:</span> &nbsp;
                <apex:outputField value="{!worder.Description}" />
            </td>
        </tr>
        <tr>
            <td></td>
            <td> </td>

        </tr>
