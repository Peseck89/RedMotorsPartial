    <formulas>
        <name>HoraInicio</name>
        <dataType>String</dataType>
        <expression>IF(
  VALUE(MID(TEXT({!$Record.StartDateTime}- (6/24)), 12, 2)) = 0 
  || VALUE(MID(TEXT({!$Record.StartDateTime} - (6/24)), 12, 2)) = 12,
  &quot;12&quot;,
  TEXT(
    VALUE(MID(TEXT({!$Record.StartDateTime} - (6/24)), 12, 2)) -
    IF(VALUE(MID(TEXT({!$Record.StartDateTime} - (6/24)), 12, 2)) &lt; 12, 0, 12)
  )
)
&amp; &quot;:&quot; &amp;
MID(TEXT({!$Record.StartDateTime} - (6/24)), 15, 2)
&amp; &quot;:&quot; &amp;
MID(TEXT({!$Record.StartDateTime} - (6/24)), 18, 2)
&amp; &quot; &quot; &amp;
IF(
  VALUE(MID(TEXT({!$Record.StartDateTime} - (6/24)), 12, 2)) &lt; 12,
  &quot;AM&quot;,
  &quot;PM&quot;
)</expression>
    </formulas>
