    <formulas>
        <name>FormulaCalculaDescuentoMayorMenor</name>
        <dataType>Boolean</dataType>
        <expression>IF(
   ({!VN_Precio_Venta_Fantasia_FX} * ({!Porcentaje_Comision_Vendedor_FM}/100)) - 
   ({!VN_Descuento_Aplicado_Monto_FX} + {!Soporte} + {!Montoderegalias}) &gt;= 0, 
   TRUE, 
   FALSE
)</expression>
    </formulas>
    <formulas>
        <name>FormulaDescuentoTotalOpp</name>
        <dataType>Number</dataType>
        <expression>(({!GetOpportunity.MontoSoporteTotal__c} + {!GetOpportunity.Valor_descuento_vehiculos_total__c} + {!GetOpportunity.MontodeRegalias__c}) / {!PrecioVenta}) * 100</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>PorcentajeAutorizadoVendedorFormula</name>
        <dataType>Number</dataType>
        <expression>{!VN_Precio_Venta_Fantasia_FX} * ({!Porcentaje_Comision_Vendedor_FM} /100)</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>PorcentajeDescuentoTotalAplicadoFormula</name>
        <dataType>Number</dataType>
        <expression>({!VN_Precio_Venta_Fantasia_FX}*({!Porcentaje_Comision_Vendedor_FM}/100) )-({!VN_Descuento_Aplicado_Monto_FX}+{!Soporte}+{!Montoderegalias})</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>TotalDescuentoFormula</name>
        <dataType>Number</dataType>
        <expression>{!VN_Descuento_Aplicado_Monto_FX} + {!Soporte} + {!Montoderegalias}</expression>
        <scale>2</scale>
    </formulas>
