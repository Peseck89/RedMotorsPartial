            </connector>
            <label>Is Status En Curso</label>
        </rules>
        <rules>
            <name>Is_Status_Pausar</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>En pausa</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>En curso</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Work_Step_Hora_Inicio_Pausa</targetReference>
            </connector>
            <label>Is Status Pausar</label>
        </rules>
        <rules>
            <name>Is_Status_Completada</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Completada</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Work_Step_EndTime</targetReference>
            </connector>
            <label>Is Status Completada</label>
        </rules>
        <rules>
            <name>Is_Status_Reanudar</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>En curso</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Hora_de_inicio_de_pausa__c</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record__Prior.Status</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>En pausa</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Work_Step_Hora_Fin_Pausa</targetReference>
            </connector>
            <label>Is Status Reanudar</label>
        </rules>
