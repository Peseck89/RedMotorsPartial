        <fields>
            <name>Telefono</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>contacto_relacionado.Phone</elementReference>
            </defaultValue>
            <fieldText>Teléfono</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;span style=&quot;color: rgb(0, 0, 0); font-size: 11.36px; font-family: Arial, Helvetica, sans-serif;&quot;&gt;El formato de teléfono debe ser +506 seguido de 8 dígitos o bien si es internacional debe comenzar con + seguido del préfijo (1-3) dígitos y el número (4-14 dígitos&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>AND(
    NOT(ISBLANK({!Telefono})),
    OR(
        NOT(BEGINS({!Telefono}, &quot;+506&quot;)),
        AND(
            BEGINS({!Telefono}, &quot;+506&quot;),
            REGEX({!Telefono}, &quot;^\\+506\\d{8}$&quot;)
        ),
        AND(
            NOT(BEGINS({!Telefono}, &quot;+506&quot;)),
            REGEX({!Telefono}, &quot;^\\+?[0-9]{1,3}[0-9]{4,14}$&quot;)
        )
    )
)</formulaExpression>
            </validationRule>
        </fields>
        <fields>
            <name>Correo</name>
            <dataType>String</dataType>
            <defaultValue>
                <elementReference>contacto_relacionado.Email</elementReference>
            </defaultValue>
            <fieldText>Correo</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>true</isRequired>
            <validationRule>
                <errorMessage>&lt;p&gt;&lt;span style=&quot;color: rgb(68, 68, 68); background-color: rgb(255, 255, 255);&quot;&gt;El formato del correo electrónico es incorrecto. Asegúrese de ingresar un correo válido como nombre@dominio.com&lt;/span&gt;&lt;/p&gt;</errorMessage>
                <formulaExpression>AND(
    NOT(ISBLANK({!Correo})),
    REGEX({!Correo}, &quot;^[a-zA-Z0-9][a-zA-Z0-9._%+-/]{0,63}@[a-zA-Z0-9][a-zA-Z0-9.-]{0,252}\\.[a-zA-Z]{2,63}$&quot;),
    NOT(
        OR(
            CONTAINS({!Correo}, &quot;..&quot;),
            REGEX({!Correo}, &quot;[.]$&quot;),
            REGEX({!Correo}, &quot;@-&quot;),
            REGEX({!Correo}, &quot;-\\.&quot;),
            CONTAINS({!Correo}, &quot; &quot;)
        )
    )
)</formulaExpression>
            </validationRule>
        </fields>
